<script>
    const API_URL = 'http://localhost:3001/api';
    const DB_KEY_REC = 'erp_rec_v19';
    const DB_KEY_CATS = 'erp_cats_v19';
    const DB_KEY_MAT_EXTRA = 'erp_mat_extra_v19';
    const DB_KEY_PROD_EXTRA = 'erp_prod_extra_v19';

    let apiOnline = false;
    let moduloAtual = 'comercial';
    let materias = [], receitas = [], produtos = [], clientes = [], pedidos = [], filaProducao = [];
    let necessidadeCompras = null;
    let textoWhatsAppCompras = '';
    let resumoFinanceiro = null, contasReceber = [];
    let filtroMat = 'todos', filtroRec = 'todos', filtroProd = 'todos';
    let tempRec = [], tempProd = [], tempPedido = [];

    const defaultCats = {
        materia: ['Geral', 'Embalagens'],
        receita: ['Geral', 'Pré-Preparo'],
        produto: ['Geral', 'Fritos', 'Assados']
    };
    let categorias = JSON.parse(localStorage.getItem(DB_KEY_CATS)) || JSON.parse(JSON.stringify(defaultCats));

    function getMatExtras() { return JSON.parse(localStorage.getItem(DB_KEY_MAT_EXTRA)) || {}; }
    function setMatExtras(data) { localStorage.setItem(DB_KEY_MAT_EXTRA, JSON.stringify(data)); }
    function getProdExtras() { return JSON.parse(localStorage.getItem(DB_KEY_PROD_EXTRA)) || {}; }
    function setProdExtras(data) { localStorage.setItem(DB_KEY_PROD_EXTRA, JSON.stringify(data)); }

    function setApiStatus(online) {
        apiOnline = online;
        const el = document.getElementById('api-status');
        el.className = 'api-status ' + (online ? 'api-online' : 'api-offline');
        el.textContent = online ? 'API online' : 'API offline';
    }

    function lerLocalStorageAntigo() {
        const parse = (k) => { try { return JSON.parse(localStorage.getItem(k) || '[]'); } catch { return []; } };
        const parseObj = (k) => { try { return JSON.parse(localStorage.getItem(k) || '{}'); } catch { return {}; } };
        const materias = parse('db_mat_v19');
        const receitas = parse('db_rec_v19').length ? parse('db_rec_v19') : parse(DB_KEY_REC);
        const produtos = parse('db_prod_v19');
        const categorias = parseObj('db_cats_v19').materia ? parseObj('db_cats_v19') : null;
        if (!materias.length && !receitas.length && !produtos.length) return null;
        return { materias, receitas, produtos, categorias: categorias || undefined };
    }

    async function importarReceitasLocaisSeNecessario(receitasAtuais) {
        const pacote = lerLocalStorageAntigo();
        if (!pacote || !pacote.receitas.length || !apiOnline) return false;
        if (receitasAtuais.length > 0) return false;
        const ok = await importarBackupCompleto(pacote, true);
        return ok.receitas > 0;
    }

    async function persistirReceitasNoBanco() {
        if (!apiOnline || !receitas.length) return;
        for (const rec of receitas) {
            try {
                await fetch(`${API_URL}/receitas/${rec.id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nome: rec.nome, categoria: rec.categoria, itens: rec.itens })
                });
            } catch (e) { /* ignora falha individual */ }
        }
    }

    async function carregarTodosOsDados() {
        const matExtra = getMatExtras();
        const prodExtra = getProdExtras();

        try {
            const [resStatus, resMat, resProd, resFila, resCli, resPed, resFin, resCR, resRec] = await Promise.all([
                fetch(`${API_URL}/status`),
                fetch(`${API_URL}/insumos`),
                fetch(`${API_URL}/produtos`),
                fetch(`${API_URL}/producao/fila`),
                fetch(`${API_URL}/comercial/clientes`),
                fetch(`${API_URL}/comercial/pedidos`),
                fetch(`${API_URL}/financeiro/resumo`),
                fetch(`${API_URL}/financeiro/contas-receber`),
                fetch(`${API_URL}/receitas`)
            ]);

            if (!resMat.ok || !resProd.ok) throw new Error('API indisponível');
            setApiStatus(resStatus.ok);

            const dadosMat = await resMat.json();
            materias = dadosMat.map(i => {
                const ex = matExtra[i.id] || {};
                return {
                    id: i.id, tipo: i.unidade_medida, nome: i.nome,
                    custoPadrao: parseFloat(i.custo_unitario),
                    categoria: ex.categoria || 'Geral',
                    precoRef: ex.precoRef, qtdRef: ex.qtdRef
                };
            });

            const dadosProd = await resProd.json();
            produtos = dadosProd.map(p => {
                const ex = prodExtra[p.id] || {};
                const mercado = parseFloat(p.preco_venda);
                const cmvPct = parseFloat(p.cmv_estimado) || 0;
                const custo = ex.custo != null ? ex.custo : mercado * (cmvPct / 100);
                return {
                    id: p.id, nome: p.nome, mercado, cmv: cmvPct,
                    margem: parseFloat(p.margem_contribuicao) || 0,
                    estoqueAtual: parseInt(p.estoque_atual, 10) || 0,
                    custo, peso: ex.peso || 0, imposto: ex.imposto != null ? ex.imposto : 10,
                    precoSugerido: ex.precoSugerido || mercado,
                    precoMinimo: ex.precoMinimo || 0,
                    itens: ex.itens || [], categoria: ex.categoria || 'Geral',
                    embalagemId: ex.embalagemId, embalagemCap: ex.embalagemCap
                };
            });

            filaProducao = resFila.ok ? await resFila.json() : [];
            clientes = resCli.ok ? await resCli.json() : [];
            pedidos = resPed.ok ? await resPed.json() : [];
            resumoFinanceiro = resFin.ok ? await resFin.json() : null;
            contasReceber = resCR.ok ? await resCR.json() : [];
            receitas = resRec.ok ? await resRec.json() : [];
            const migrou = await importarReceitasLocaisSeNecessario(receitas);
            if (migrou) {
                const resRec2 = await fetch(`${API_URL}/receitas`);
                receitas = resRec2.ok ? await resRec2.json() : [];
            }
        } catch (e) {
            console.error(e);
            setApiStatus(false);
            receitas = [];
        }

        recalcularCascata(false);
        renderFilters();
        renderGrids();
        renderFinanceiro();
        await carregarNecessidadeCompras(true);
    }

    function mudarModulo(mod) {
        moduloAtual = mod;
        document.querySelectorAll('.modulo').forEach(m => m.classList.remove('active'));
        document.querySelectorAll('.module-nav button').forEach(b => b.classList.remove('active'));
        document.getElementById('modulo-' + mod).classList.add('active');
        document.getElementById('mod-nav-' + mod).classList.add('active');
        const defaults = { comercial: 'pedidos', producao: 'materia', financeiro: 'dashboard' };
        mudarSubAba(mod, defaults[mod]);
    }

    function mudarSubAba(mod, aba) {
        const map = {
            comercial: ['pedidos', 'clientes'],
            producao: ['materia', 'receitas', 'produtos', 'fabrica', 'compras'],
            financeiro: ['dashboard', 'receber']
        };
        map[mod].forEach(id => {
            const sec = document.getElementById((mod === 'comercial' ? 'com-' : mod === 'producao' ? 'prod-' : 'fin-') + id);
            const btn = document.getElementById('sub-' + mod + '-' + id);
            if (sec) sec.classList.remove('active');
            if (btn) btn.classList.remove('active');
        });
        const prefix = mod === 'comercial' ? 'com-' : mod === 'producao' ? 'prod-' : 'fin-';
        document.getElementById(prefix + aba).classList.add('active');
        document.getElementById('sub-' + mod + '-' + aba).classList.add('active');
    }

    // --- BACKUP E IMPORTAÇÃO ---
    function abrirModalSistema() {
        document.getElementById('modal-sistema').classList.add('open');
        document.getElementById('import-status').innerText = '';
    }
    function baixarBackup() {
        const dados = { materias, receitas, produtos, categorias, matExtra: getMatExtras(), prodExtra: getProdExtras(), versao: 'erp_v2' };
        const a = document.createElement('a');
        a.href = 'data:text/json;charset=utf-8,' + encodeURIComponent(JSON.stringify(dados));
        a.download = 'backup_erp_fabrica_' + new Date().toISOString().split('T')[0] + '.json';
        a.click();
    }

    function setImportStatus(msg) {
        const el = document.getElementById('import-status');
        if (el) el.innerText = msg;
    }

    async function buscarInsumosExistentes() {
        const res = await fetch(`${API_URL}/insumos`);
        return res.ok ? await res.json() : [];
    }

    async function criarOuMapearInsumo(m, mapaInsumo, matExtra, insumosExistentes) {
        const existente = insumosExistentes.find(i => i.nome === m.nome && i.unidade_medida === (m.tipo || m.unidade_medida));
        if (existente) {
            mapaInsumo[String(m.id)] = existente.id;
            matExtra[existente.id] = {
                categoria: m.categoria || 'Geral',
                precoRef: m.precoRef,
                qtdRef: m.qtdRef
            };
            return existente.id;
        }
        const res = await fetch(`${API_URL}/insumos`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                nome: m.nome,
                unidade_medida: m.tipo || m.unidade_medida || 'kg',
                custo_unitario: parseFloat(m.custoPadrao ?? m.custo_unitario)
            })
        });
        if (!res.ok) throw new Error('Falha ao criar insumo ' + m.nome);
        const saved = await res.json();
        mapaInsumo[String(m.id)] = saved.id;
        matExtra[saved.id] = {
            categoria: m.categoria || 'Geral',
            precoRef: m.precoRef,
            qtdRef: m.qtdRef
        };
        insumosExistentes.push(saved);
        return saved.id;
    }

    function explodeFichaFromItens(itens, receitasArr) {
        const mapa = {};
        (itens || []).forEach(item => {
            if ((item.tipoOrigem || item.tipo_origem) === 'materia') {
                const qty = item.g / 1000;
                const id = item.idOrigem ?? item.origem_id;
                mapa[id] = (mapa[id] || 0) + qty;
            } else {
                const rec = receitasArr.find(r => String(r.id) === String(item.idOrigem ?? item.origem_id));
                if (!rec || !rec.pesoTotal) return;
                rec.itens.forEach(sub => {
                    if ((sub.tipoOrigem || sub.tipo_origem) !== 'materia') return;
                    const qty = ((sub.g / rec.pesoTotal) * item.g) / 1000;
                    const sid = sub.idOrigem ?? sub.origem_id;
                    mapa[sid] = (mapa[sid] || 0) + qty;
                });
            }
        });
        return Object.entries(mapa).map(([insumo_id, quantidade]) => ({
            insumo_id: Number(insumo_id),
            quantidade
        })).filter(f => f.quantidade > 0);
    }

    async function importarBackupCompleto(json, silencioso) {
        if (!apiOnline) {
            alert('API offline. Inicie o backend na porta 3001 antes de importar.');
            return { insumos: 0, receitas: 0, produtos: 0, erros: ['API offline'] };
        }

        const stats = { insumos: 0, receitas: 0, produtos: 0, erros: [] };
        const mapaInsumo = {};
        const matExtra = { ...getMatExtras(), ...(json.matExtra || {}) };
        const prodExtra = { ...getProdExtras(), ...(json.prodExtra || {}) };

        if (json.categorias) {
            categorias = json.categorias;
            localStorage.setItem(DB_KEY_CATS, JSON.stringify(categorias));
        }

        setImportStatus('Importando insumos...');
        const insumosExistentes = await buscarInsumosExistentes();
        const listaMaterias = json.materias || [];

        for (const m of listaMaterias) {
            try {
                await criarOuMapearInsumo(m, mapaInsumo, matExtra, insumosExistentes);
                stats.insumos++;
            } catch (e) {
                stats.erros.push('Insumo ' + m.nome + ': ' + e.message);
            }
        }
        setMatExtras(matExtra);

        const listaReceitas = json.receitas || [];
        if (listaReceitas.length) {
            setImportStatus('Importando receitas...');
            try {
                const res = await fetch(`${API_URL}/receitas/importar`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ receitas: listaReceitas, mapa_insumos: mapaInsumo })
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.erro || 'Erro nas receitas');
                stats.receitas = data.importadas || 0;
            } catch (e) {
                stats.erros.push('Receitas: ' + e.message);
            }
        }

        setImportStatus('Carregando receitas do banco...');
        const resRec = await fetch(`${API_URL}/receitas`);
        const receitasDb = resRec.ok ? await resRec.json() : [];
        const mapaReceita = {};
        listaReceitas.forEach(old => {
            const match = receitasDb.find(r => r.nome === old.nome);
            if (match) mapaReceita[String(old.id)] = match.id;
        });

        const listaProdutos = json.produtos || [];
        if (listaProdutos.length) {
            setImportStatus('Importando produtos...');
            for (const p of listaProdutos) {
                try {
                    const itensRemap = (p.itens || []).map(item => ({
                        ...item,
                        tipoOrigem: item.tipoOrigem || item.tipo_origem,
                        idOrigem: (item.tipoOrigem || item.tipo_origem) === 'materia'
                            ? (mapaInsumo[String(item.idOrigem)] ?? item.idOrigem)
                            : (mapaReceita[String(item.idOrigem)] ?? item.idOrigem),
                        g: item.g
                    }));
                    const ficha = explodeFichaFromItens(itensRemap, receitasDb);
                    if (!ficha.length) throw new Error('ficha técnica vazia');

                    const precoPraticado = parseFloat(p.mercado || p.preco_venda || p.precoSugerido || 0);
                    const custo = parseFloat(p.custo || 0);
                    const cmv = p.cmv != null ? parseFloat(p.cmv) : (precoPraticado > 0 ? (custo / precoPraticado) * 100 : 0);
                    const margem = p.margem != null ? parseFloat(p.margem) : parseFloat(p.margem_contribuicao || 0);

                    const res = await fetch(`${API_URL}/produtos`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            nome: p.nome,
                            preco_venda: precoPraticado,
                            cmv_estimado: cmv,
                            margem_contribuicao: margem,
                            ficha_tecnica: ficha
                        })
                    });
                    if (!res.ok) throw new Error('API recusou');
                    const result = await res.json();
                    prodExtra[result.produto_id] = {
                        categoria: p.categoria || 'Geral',
                        imposto: p.imposto != null ? p.imposto : 10,
                        peso: p.peso || 0,
                        custo,
                        precoSugerido: p.precoSugerido || precoPraticado,
                        precoMinimo: p.precoMinimo || 0,
                        itens: itensRemap,
                        embalagemId: mapaInsumo[String(p.embalagemId)] || p.embalagemId,
                        embalagemCap: p.embalagemCap
                    };
                    stats.produtos++;
                } catch (e) {
                    stats.erros.push('Produto ' + p.nome + ': ' + e.message);
                }
            }
        }
        setProdExtras(prodExtra);

        localStorage.removeItem('db_mat_v19');
        localStorage.removeItem('db_rec_v19');
        localStorage.removeItem('db_prod_v19');
        localStorage.removeItem('db_cats_v19');
        localStorage.removeItem(DB_KEY_REC);

        if (!silencioso) {
            const msg = `✅ ${stats.insumos} insumos, ${stats.receitas} receitas, ${stats.produtos} produtos importados.` +
                (stats.erros.length ? '\n⚠️ Erros:\n' + stats.erros.join('\n') : '');
            setImportStatus(msg.replace(/\n/g, ' '));
            alert(msg);
        }
        return stats;
    }

    async function restaurarBackup() {
        const input = document.getElementById('file-upload');
        if (!input.files.length) return alert('Selecione um arquivo .json');
        const reader = new FileReader();
        reader.onload = async function(ev) {
            try {
                const json = JSON.parse(ev.target.result);
                if (!confirm('Importar dados do arquivo para o banco PostgreSQL?\n\nNovos registros serão criados (insumos duplicados pelo nome serão reutilizados).')) return;
                await importarBackupCompleto(json, false);
                fecharModais();
                await carregarTodosOsDados();
            } catch (e) {
                console.error(e);
                alert('Erro ao ler arquivo: ' + e.message);
            }
        };
        reader.readAsText(input.files[0]);
    }

    async function importarDoLocalStorageNavegador() {
        const pacote = lerLocalStorageAntigo();
        if (!pacote) return alert('Nenhum dado encontrado no localStorage.\n\nAbra o Sistema Fábrica no navegador (Chrome/Edge), ou importe um arquivo .json de backup.');
        const qtd = (pacote.materias?.length || 0) + (pacote.receitas?.length || 0) + (pacote.produtos?.length || 0);
        if (!confirm(`Encontrados no navegador:\n• ${pacote.materias?.length || 0} insumos\n• ${pacote.receitas?.length || 0} receitas\n• ${pacote.produtos?.length || 0} produtos\n\nImportar ${qtd} itens para o PostgreSQL?`)) return;
        setImportStatus('Importando...');
        await importarBackupCompleto(pacote, false);
        fecharModais();
        await carregarTodosOsDados();
    }

    // --- FILTROS E CATEGORIAS ---
    function renderFilters() {
        if (!categorias.materia) categorias.materia = ['Geral'];
        if (!categorias.receita) categorias.receita = ['Geral'];
        if (!categorias.produto) categorias.produto = ['Geral'];
        const draw = (t, curr, id) => {
            const el = document.getElementById(id);
            if (!el) return;
            el.innerHTML = `<button class="filter-btn ${curr === 'todos' ? 'active' : ''}" onclick="setFilter('${t}','todos')">Todos</button>` +
                categorias[t].map(c => `<button class="filter-btn ${curr === c ? 'active' : ''}" onclick="setFilter('${t}','${c.replace(/'/g, "\\'")}')">${c}</button>`).join('');
        };
        draw('materia', filtroMat, 'filter-materia');
        draw('receita', filtroRec, 'filter-receita');
        draw('produto', filtroProd, 'filter-produto');
    }
    function setFilter(t, v) {
        if (t === 'materia') filtroMat = v;
        if (t === 'receita') filtroRec = v;
        if (t === 'produto') filtroProd = v;
        renderFilters();
        renderGrids();
    }
    function abrirGestorCategorias(t) {
        document.getElementById('modal-categorias').classList.add('open');
        document.getElementById('tipo-gestao-atual').value = t;
        document.getElementById('titulo-gestor-cat').innerText = 'Gerenciar: ' + t.toUpperCase();
        renderCatList(t);
    }
    function renderCatList(t) {
        document.getElementById('lista-categorias-existentes').innerHTML = categorias[t].map((c, i) =>
            `<div class="cat-list-item"><span>${c}</span><button onclick="rmCat('${t}',${i})" style="color:red;border:none;cursor:pointer;background:none;">X</button></div>`
        ).join('');
    }
    function adicionarCategoria() {
        const t = document.getElementById('tipo-gestao-atual').value;
        const n = document.getElementById('nova-cat-nome').value.trim();
        if (!n) return;
        categorias[t].push(n);
        document.getElementById('nova-cat-nome').value = '';
        localStorage.setItem(DB_KEY_CATS, JSON.stringify(categorias));
        renderCatList(t);
        renderFilters();
    }
    function rmCat(t, i) {
        categorias[t].splice(i, 1);
        localStorage.setItem(DB_KEY_CATS, JSON.stringify(categorias));
        renderCatList(t);
        renderFilters();
        renderGrids();
    }

    // --- INSUMOS ---
    function abrirModalMateria(id) {
        document.getElementById('modal-materia').classList.add('open');
        popSelect('materia', 'mat-categoria');
        if (id) {
            const m = materias.find(x => x.id == id);
            if (!m) return;
            setVal('edit-mat-id', m.id);
            setVal('mat-nome', m.nome);
            setVal('mat-tipo', m.tipo);
            setVal('mat-categoria', m.categoria);
            setVal('mat-preco', m.precoRef || '');
            setVal('mat-qtd', m.qtdRef || '');
        } else {
            resetForm(['edit-mat-id', 'mat-nome', 'mat-preco', 'mat-qtd']);
        }
        atualizarLabelPeso();
    }

    async function salvarMateria() {
        const id = document.getElementById('edit-mat-id').value;
        const nome = document.getElementById('mat-nome').value;
        const preco = parseFloat(document.getElementById('mat-preco').value);
        const qtd = parseFloat(document.getElementById('mat-qtd').value);
        const tipo = document.getElementById('mat-tipo').value;
        const cat = document.getElementById('mat-categoria').value;
