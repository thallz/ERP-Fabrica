    </div>
    <div class="container">
        <section id="com-pedidos" class="sub-section active">
            <div class="header-actions">
                <h2>Pedidos de Venda</h2>
                <button class="btn-primary" onclick="abrirModalPedido()">+ Lançar Pedido</button>
            </div>
            <div id="grid-pedidos" class="data-table-wrap"></div>
        </section>
        <section id="com-clientes" class="sub-section">
            <div class="header-actions">
                <h2>Clientes B2B</h2>
                <button class="btn-primary" onclick="abrirModalCliente()">+ Novo Cliente</button>
            </div>
            <div id="grid-clientes" class="cards-grid"></div>
        </section>
    </div>
</div>

<!-- MÓDULO PRODUÇÃO -->
<div id="modulo-producao" class="modulo">
    <div class="sub-nav">
        <button onclick="mudarSubAba('producao','materia')" id="sub-producao-materia" class="active">Almoxarifado</button>
        <button onclick="mudarSubAba('producao','receitas')" id="sub-producao-receitas">Receitas</button>
        <button onclick="mudarSubAba('producao','produtos')" id="sub-producao-produtos">Produtos</button>
        <button onclick="mudarSubAba('producao','fabrica')" id="sub-producao-fabrica">Chão de Fábrica</button>
        <button onclick="mudarSubAba('producao','compras')" id="sub-producao-compras">Lista de Compras</button>
    </div>
    <div class="container">
        <section id="prod-materia" class="sub-section active">
            <div class="header-actions">
                <h2>Almoxarifado</h2>
                <div class="btn-group">
                    <button class="btn-config" onclick="abrirGestorCategorias('materia')">⚙️ Categorias</button>
                    <button class="btn-primary" onclick="abrirModalMateria()">+ Novo Insumo</button>
                </div>
            </div>
            <div id="filter-materia" class="filter-bar"></div>
            <div id="grid-materias" class="cards-grid"></div>
        </section>
        <section id="prod-receitas" class="sub-section">
            <div class="header-actions">
                <h2>Receitas (Massas/Recheios)</h2>
                <div class="btn-group">
                    <button class="btn-config" onclick="abrirGestorCategorias('receita')">⚙️ Categorias</button>
                    <button class="btn-primary" onclick="abrirModalReceita()">+ Nova Receita</button>
                </div>
            </div>
            <div id="filter-receita" class="filter-bar"></div>
            <div id="grid-receitas" class="cards-grid"></div>
        </section>
        <section id="prod-produtos" class="sub-section">
            <div class="header-actions">
                <h2>Engenharia de Produtos</h2>
                <div class="btn-group">
                    <button class="btn-config" onclick="window.print()">🖨️ Imprimir Tabela</button>
                    <button class="btn-config" onclick="abrirGestorCategorias('produto')">⚙️ Categorias</button>
                    <button class="btn-primary" onclick="abrirModalProduto()">+ Novo Produto</button>
                </div>
            </div>
            <div id="filter-produto" class="filter-bar"></div>
            <div id="grid-produtos" class="cards-grid"></div>
        </section>
        <section id="prod-fabrica" class="sub-section">
            <div class="header-actions">
                <h2>Fila de Produção</h2>
                <div class="btn-group">
                    <button class="btn-config" onclick="window.open('calculadora.html','_blank')">🧮 Calculadora Completa</button>
                    <button class="btn-primary" onclick="abrirModalNovaOP()">+ Lançar OP</button>
                </div>
            </div>
            <div id="grid-producao" class="cards-grid"></div>
        </section>
        <section id="prod-compras" class="sub-section">
            <div class="header-actions">
                <h2>MRP — Necessidade de Compras</h2>
                <div class="btn-group">
                    <select id="mrp-margem" onchange="carregarNecessidadeCompras()" style="padding:10px; border-radius:8px; border:1px solid var(--border);">
                        <option value="0">Margem 0%</option>
                        <option value="0.05" selected>Margem 5%</option>
                        <option value="0.10">Margem 10%</option>
                    </select>
                    <button class="btn-config" onclick="carregarNecessidadeCompras()">🔄 Atualizar</button>
                    <button class="btn-config" onclick="enviarWhatsAppCompras()">📱 WhatsApp</button>
                    <button class="btn-config" onclick="window.print()">🖨️ Imprimir</button>
                </div>
            </div>
            <div id="mrp-avisos" style="margin-bottom:15px;"></div>
            <div id="grid-compras" class="data-table-wrap"></div>
        </section>
    </div>
</div>

<!-- MÓDULO FINANCEIRO -->
<div id="modulo-financeiro" class="modulo">
    <div class="sub-nav">
        <button onclick="mudarSubAba('financeiro','dashboard')" id="sub-financeiro-dashboard" class="active">Visão Geral</button>
        <button onclick="mudarSubAba('financeiro','receber')" id="sub-financeiro-receber">Contas a Receber</button>
    </div>
    <div class="container">
        <section id="fin-dashboard" class="sub-section active">
            <div class="header-actions"><h2>Indicadores Financeiros</h2></div>
            <div id="kpi-financeiro" class="kpi-grid"></div>
            <div id="grid-status-pedidos" class="data-table-wrap"></div>
        </section>
        <section id="fin-receber" class="sub-section">
            <div class="header-actions"><h2>Contas a Receber</h2></div>
            <div id="grid-contas-receber" class="data-table-wrap"></div>
        </section>
    </div>
</div>

<!-- MODAL BACKUP -->
<div id="modal-sistema" class="modal-overlay">
    <div class="modal-content" style="text-align:center;">
        <button class="close-modal" onclick="fecharModais()">&times;</button>
        <h3>Backup e Segurança</h3>
        <div style="display:grid; gap:15px; margin-top:20px;">
            <div style="background:#f0f9ff; padding:20px; border-radius:10px; border:1px solid #bae6fd;">
                <h4>1. Salvar Dados Locais</h4>
                <p style="font-size:0.85rem; color:#64748b;">Receitas, categorias e fichas técnicas detalhadas</p>
                <button class="btn-primary" onclick="baixarBackup()">⬇️ Baixar Arquivo</button>
            </div>
            <div style="background:#fff7ed; padding:20px; border-radius:10px; border:1px solid #fed7aa;">
                <h4>2. Importar Backup (.json)</h4>
                <p style="font-size:0.8rem; color:#64748b;">Aceita backup do Sistema Fábrica (navegador) ou do ERP</p>
                <input type="file" id="file-upload" accept=".json" style="margin-bottom:10px; width:100%;">
                <button class="btn-config" style="background:#d97706; color:white; width:100%; margin-bottom:10px;" onclick="restaurarBackup()">⬆️ Carregar Arquivo JSON</button>
                <button class="btn-primary" style="width:100%;" onclick="importarDoLocalStorageNavegador()">🌐 Importar do localStorage (só no navegador)</button>
                <p style="font-size:0.75rem; color:#92400e; margin-top:8px;">No Electron: exporte o .json no Chrome onde rodava o Sistema Fábrica e use "Carregar Arquivo".</p>
                <p id="import-status" style="font-size:0.8rem; color:#64748b; margin-top:10px;"></p>
            </div>
        </div>
    </div>
</div>

<!-- MODAL CATEGORIAS -->
<div id="modal-categorias" class="modal-overlay">
    <div class="modal-content">
        <button class="close-modal" onclick="fecharModais()">&times;</button>
        <h3 id="titulo-gestor-cat">Categorias</h3>
        <input type="hidden" id="tipo-gestao-atual">
        <div style="display:flex; gap:10px; margin-bottom:20px;">
            <input type="text" id="nova-cat-nome" placeholder="Nome..." style="flex:1; padding:8px; border:1px solid #ccc; border-radius:4px;">
            <button onclick="adicionarCategoria()" class="btn-primary">Adicionar</button>
        </div>
        <div id="lista-categorias-existentes" style="max-height:300px; overflow-y:auto;"></div>
    </div>
</div>

<!-- MODAL INSUMO -->
<div id="modal-materia" class="modal-overlay">
    <div class="modal-content">
        <button class="close-modal" onclick="fecharModais()">&times;</button>
        <h3>Cadastro de Insumo</h3>
        <input type="hidden" id="edit-mat-id">
        <div class="grid-form">
            <div class="input-group"><label>Tipo</label><select id="mat-tipo" onchange="atualizarLabelPeso()"><option value="kg">Peso (Kg)</option><option value="un">Unidade (Un)</option></select></div>
            <div class="input-group"><label>Categoria</label><select id="mat-categoria"></select></div>
        </div>
        <div class="input-group" style="margin-bottom:15px;"><label>Nome</label><input type="text" id="mat-nome"></div>
        <div class="grid-form">
            <div class="input-group"><label>Preço Pago (R$)</label><input type="number" id="mat-preco" step="0.01"></div>
            <div class="input-group"><label id="lbl-mat-qtd">Peso TOTAL da Embalagem (g)</label><input type="number" id="mat-qtd" placeholder="ex: 1000 para 1kg"></div>
        </div>
        <small style="color:#d97706; display:block; margin-top:-10px; margin-bottom:10px;">* Se comprou 1Kg, digite 1000g. Se comprou 500g, digite 500.</small>
        <button class="btn-primary" style="width:100%" onclick="salvarMateria()">Gravar no Banco</button>
    </div>
</div>

<!-- MODAL RECEITA -->
<div id="modal-receita" class="modal-overlay">
    <div class="modal-content">
        <button class="close-modal" onclick="fecharModais()">&times;</button>
        <h3>Receita</h3>
        <input type="hidden" id="edit-rec-id">
        <div class="grid-form">
            <div class="input-group"><label>Nome da Receita</label><input type="text" id="rec-nome"></div>
            <div class="input-group"><label>Categoria</label><select id="rec-categoria"></select></div>
        </div>
        <div style="background:#f1f5f9; padding:15px; border-radius:8px; margin-bottom:15px;">
            <label style="font-size:0.8rem; font-weight:bold; margin-bottom:5px; display:block;">Adicionar Ingrediente:</label>
            <div style="display:flex; gap:10px; flex-wrap:wrap;">
                <select id="rec-tipo-origem" style="flex:1; min-width:120px;" onchange="atualizarSelectReceita()"><option value="materia">Matéria-Prima</option><option value="receita">Pré-Preparo</option></select>
                <select id="rec-select" style="flex:2; min-width:150px;"></select>
                <input type="number" id="rec-qtd" placeholder="Gramas" style="flex:1; min-width:80px;">
                <button onclick="addTempRec()" style="background:var(--primary); color:white; border:none; padding:10px 15px; border-radius:6px; cursor:pointer;">+</button>
            </div>
        </div>
        <div id="lista-temp-rec" class="temp-list"></div>
        <button class="btn-primary" style="width:100%" onclick="salvarReceita()">Salvar Receita</button>
    </div>
</div>

<!-- MODAL PRODUTO -->
<div id="modal-produto" class="modal-overlay">
    <div class="modal-content">
        <button class="close-modal" onclick="fecharModais()">&times;</button>
        <h3>Produto Final e Precificação</h3>
        <input type="hidden" id="edit-prod-id">
        <div class="grid-form">
            <div class="input-group"><label>Nome do Produto</label><input type="text" id="prod-nome"></div>
            <div class="input-group"><label>Categoria</label><select id="prod-categoria"></select></div>
            <div class="input-group"><label>Impostos (%)</label><input type="number" id="prod-imposto" value="10" oninput="recalcularLive()"></div>
            <div class="input-group"><label>Preço de Venda (R$)</label><input type="number" id="prod-mercado"></div>
        </div>
        <div style="background:#f1f5f9; padding:15px; border-radius:8px; margin-bottom:15px;">
            <div style="display:flex; gap:10px; flex-wrap:wrap;">
                <select id="prod-tipo-origem" style="flex:1; min-width:120px;" onchange="atualizarSelectProduto()"><option value="materia">Matéria-Prima</option><option value="receita">Receita</option></select>
                <select id="prod-select" style="flex:3; min-width:150px;"></select>
                <input type="number" id="prod-qtd" placeholder="Gramas" style="flex:1; min-width:80px;">
                <button onclick="addTempProd()" style="background:var(--primary); color:white; border:none; padding:0 15px; border-radius:6px; cursor:pointer;">+</button>
            </div>
        </div>
        <div id="lista-temp-prod" class="temp-list"></div>
        <div class="pack-area">
            <span style="font-weight:bold; color:#d97706; font-size:0.9rem;">📦 Embalagem (Unidade)</span>
            <div class="grid-form" style="margin-bottom:0; margin-top:10px;">
                <div class="input-group"><label>Caixa</label><select id="prod-pack-select" onchange="recalcularLive()"></select></div>
                <div class="input-group"><label>Capacidade</label><input type="number" id="prod-pack-cap" placeholder="Ex: 15" oninput="recalcularLive()"></div>
            </div>
            <div style="text-align:right; font-size:0.85rem; color:#9a3412; margin-top:5px;">Rateio: <strong id="pack-cost-display">R$ 0,00</strong></div>
        </div>
        <div class="live-summary">
            <div>Peso: <span id="live-peso">0</span>g</div>
            <div>Margem: <span id="live-margem">0</span>%</div>
            <div>Sugerido: <span id="live-preco">R$ 0,00</span></div>
        </div>
        <button class="btn-primary" style="width:100%" onclick="salvarProduto()">Salvar Ficha Técnica no Banco</button>
    </div>
</div>

<!-- MODAIS COMERCIAL -->
<div id="modal-cliente" class="modal-overlay">
    <div class="modal-content">
