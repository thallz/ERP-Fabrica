<!-- Toast container -->
<div id="toast-container"></div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
  const API = 'http://localhost:3001/api';

  function fmtBRL(v) {
    return Number(v || 0).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
  }

  function toast(msg, type = '') {
    const el = document.createElement('div');
    el.className = 'toast ' + type;
    el.textContent = msg;
    document.getElementById('toast-container').appendChild(el);
    setTimeout(() => el.remove(), 3500);
  }

  // --- Chart ---
  let chart;
  function initChart(data) {
    const ctx = document.getElementById('salesChart').getContext('2d');
    if (chart) chart.destroy();
    chart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: data.labels,
        datasets: [{
          data: data.values,
          backgroundColor: '#5b4be3',
          borderRadius: 6,
          borderSkipped: false,
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: {
          callbacks: { label: ctx => fmtBRL(ctx.raw) }
        }},
        scales: {
          x: { grid: { display: false }, ticks: { font: { family: 'Inter', size: 11 } } },
          y: { grid: { color: '#f0f1f5' }, ticks: { font: { family: 'Inter', size: 11 }, callback: v => 'R$' + (v/1000).toFixed(0) + 'k' } }
        }
      }
    });
  }

  // --- Queue render ---
  function renderQueue(ops) {
    const list = document.getElementById('queue-list');
    if (!ops || !ops.length) {
      list.innerHTML = '<li style="color:var(--text-muted);font-size:13px;padding:8px 0">Nenhuma OP na fila.</li>';
      return;
    }
    const statusMap = {
      'FILA':      { label: 'Aguardando',  cls: 'badge-amber' },
      'PRODUZINDO':{ label: 'Em progresso',cls: 'badge-blue' },
      'CONCLUIDA': { label: 'Concluida',   cls: 'badge-green' },
      'PAUSADA':   { label: 'Pausada',     cls: 'badge-gray' },
    };
    list.innerHTML = ops.slice(0, 6).map(op => {
      const s = statusMap[op.status] || { label: op.status, cls: 'badge-gray' };
      return `
        <li class="queue-item">
          <div class="queue-item-header">
            <span class="queue-item-op">OP-${String(op.id).padStart(3,'0')}</span>
            <span class="badge ${s.cls}" style="font-size:10px">${s.label}</span>
          </div>
          <div class="queue-item-title">${op.produto_nome || 'Produto #' + op.produto_id}</div>
          <div class="queue-item-sub">Qtd planejada: ${op.quantidade_planejada}</div>
        </li>`;
    }).join('');
  }

  // --- Load all dashboard data ---
  async function loadDashboard() {
    try {
      const [financeiro, ops] = await Promise.all([
        fetch(`${API}/financeiro/resumo`).then(r => r.json()),
        fetch(`${API}/producao/fila`).then(r => r.json()).catch(() => [])
      ]);

      document.getElementById('kpi-faturamento').textContent = fmtBRL(financeiro.faturamento_total);
      document.getElementById('kpi-pedidos-sub').textContent = `${financeiro.total_pedidos} pedidos realizados`;

      const produzindo = (financeiro.pedidos_por_status || []).find(s => s.status === 'PRODUZINDO');
      document.getElementById('kpi-producao').textContent = produzindo ? produzindo.quantidade : '0';
      document.getElementById('kpi-producao-sub').textContent = 'OPs para finalizar hoje';

      document.getElementById('kpi-receber').textContent = fmtBRL(financeiro.a_receber);
      document.getElementById('kpi-receber-sub').textContent = 'A receber de pedidos ativos';

      // Estoque critico — mock enquanto endpoint nao existe
      document.getElementById('kpi-critico').textContent = '—';

      renderQueue(ops);

      // Chart: últimos 6 dias baseado em pedidos_por_status mock
      const days = ['Seg','Ter','Qua','Qui','Sex','Sab'];
      const vals = [4500, 4800, 4600, 6000, 5800, 3100];
      initChart({ labels: days, values: vals });

    } catch (err) {
      console.error('[ERP] Dashboard error:', err);
      toast('Servidor offline — dados de demonstracao.', 'error');

      // Fallback demo
      document.getElementById('kpi-faturamento').textContent = 'R$ 12.450,00';
      document.getElementById('kpi-pedidos-sub').textContent = '14 pedidos realizados';
      document.getElementById('kpi-producao').textContent = '28';
      document.getElementById('kpi-producao-sub').textContent = '8 OPs para finalizar hoje';
      document.getElementById('kpi-receber').textContent = 'R$ 4.200,00';
      document.getElementById('kpi-receber-sub').textContent = '3 titulos com +15 dias';
      document.getElementById('kpi-critico').textContent = '12 itens';

      const demoOps = [
        { id:1, status:'PRODUZINDO', produto_nome:'Metalurgica Silva', quantidade_planejada: 200 },
        { id:3, status:'FILA',       produto_nome:'Auto Pecas Central', quantidade_planejada: 80 },
        { id:4, status:'PRODUZINDO', produto_nome:'Industrias Knorr',   quantidade_planejada: 50 },
        { id:7, status:'FILA',       produto_nome:'Logistica Express',  quantidade_planejada: 120 },
        { id:9, status:'FILA',       produto_nome:'Construtora Norte',  quantidade_planejada: 60 },
      ];
      renderQueue(demoOps);
      initChart({ labels:['Seg','Ter','Qua','Qui','Sex','Sab'], values:[4500,4800,4600,6000,5800,3100] });
    }
  }

  document.addEventListener('DOMContentLoaded', loadDashboard);
  document.addEventListener('keydown', e => {
    if (e.altKey && e.key === 's') document.querySelector('.topbar-search').focus();
  });
</script>
</body>
</html>
