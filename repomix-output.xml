    // --- MATEMÁTICA EM CASCATA ---
    function sincronizarNomes(tipo, idRef, novoNome) {
        receitas.forEach(rec => rec.itens.forEach(item => {
            if (item.tipoOrigem === tipo && String(item.idOrigem) === String(idRef)) item.nome = novoNome;
        }));
        produtos.forEach(prod => prod.itens.forEach(item => {
            if (item.tipoOrigem === tipo && String(item.idOrigem) === String(idRef)) item.nome = novoNome;
        }));
        const extras = getProdExtras();
        produtos.forEach(p => { if (p.itens) extras[p.id] = { ...extras[p.id], itens: p.itens }; });
        setProdExtras(extras);
        persistirReceitasNoBanco();
    }

    function recalcularCascata(salvarNoBanco) {
        const updateRec = (rec) => {
            let totalCusto = 0, totalPeso = 0;
            rec.itens.forEach(item => {
                let custo = 0;
                if (item.tipoOrigem === 'materia') {
                    const m = materias.find(x => String(x.id) === String(item.idOrigem));
                    if (m) custo = (m.custoPadrao / 1000) * item.g;
                } else {
                    const r = receitas.find(x => String(x.id) === String(item.idOrigem));
                    if (r) custo = (r.custoPorKg / 1000) * item.g;
                }
                item.custo = custo;
                totalCusto += custo;
                totalPeso += item.g;
            });
            rec.custo = totalCusto;
            rec.pesoTotal = totalPeso;
            rec.custoPorKg = totalPeso > 0 ? (totalCusto / totalPeso) * 1000 : 0;
        };
        receitas.forEach(updateRec);
        receitas.forEach(updateRec);

        produtos.forEach(p => {
            if (!p.itens || !p.itens.length) return;
            let custoItens = 0, peso = 0;
            p.itens.forEach(item => {
                let c = 0;
                if (item.tipoOrigem === 'receita') {
                    const r = receitas.find(rec => String(rec.id) === String(item.idOrigem));
                    if (r) c = (r.custoPorKg / 1000) * item.g;
                } else {
                    const m = materias.find(mat => String(mat.id) === String(item.idOrigem));
                    if (m) c = (m.custoPadrao / 1000) * item.g;
                }
                item.custo = c;
                custoItens += c;
                peso += item.g;
            });
            let ce = 0;
            if (p.embalagemId && p.embalagemCap > 0) {
                const e = materias.find(m => String(m.id) === String(p.embalagemId));
                if (e) ce = (e.tipo === 'un' ? e.custoPadrao : e.custoPadrao / 1000) / p.embalagemCap;
            }
            p.custo = custoItens + ce;
            p.peso = peso;
            const imp = p.imposto || 10;
            const margem = peso < 100 ? 0.60 : 0.50;
            const div = 1 - ((imp / 100) + margem);
            p.precoSugerido = p.custo / (div > 0 ? div : 0.1);
            p.precoMinimo = p.custo / (1 - (imp / 100));
            if (p.mercado > 0) {
                p.cmv = (p.custo / p.mercado) * 100;
                p.margem = (1 - (imp / 100) - (p.custo / p.mercado)) * 100;
            }
        });

        renderGrids();
        if (salvarNoBanco) persistirReceitasNoBanco();
    }

    // --- SELECTS E TEMPS ---
    function atualizarSelectReceita() {
        const t = document.getElementById('rec-tipo-origem').value;
        const idEdit = String(document.getElementById('edit-rec-id').value);
        const list = t === 'materia' ? materias.filter(m => m.tipo === 'kg') : receitas.filter(r => String(r.id) !== idEdit);
        document.getElementById('rec-select').innerHTML = list.map(i => `<option value="${i.id}">${i.nome}</option>`).join('');
    }

    function atualizarSelectProduto() {
        const t = document.getElementById('prod-tipo-origem').value;
        const list = t === 'materia' ? materias.filter(m => m.tipo === 'kg') : receitas;
        document.getElementById('prod-select').innerHTML = list.map(i => `<option value="${i.id}">${i.nome}</option>`).join('');
    }

    function addTempRec() {
        const t = document.getElementById('rec-tipo-origem').value;
        const id = document.getElementById('rec-select').value;
        const qtd = parseFloat(document.getElementById('rec-qtd').value);
        const item = (t === 'materia' ? materias : receitas).find(x => String(x.id) === String(id));
        if (!item || !qtd) return;
        const custoUnit = t === 'materia' ? item.custoPadrao : item.custoPorKg;
        tempRec.push({ nome: item.nome, idOrigem: item.id, tipoOrigem: t, g: qtd, custoUnitario: custoUnit, custo: (custoUnit / 1000) * qtd });
        document.getElementById('rec-qtd').value = '';
        renderTempRec();
    }

    function addTempProd() {
        const t = document.getElementById('prod-tipo-origem').value;
        const id = document.getElementById('prod-select').value;
        const qtd = parseFloat(document.getElementById('prod-qtd').value);
        const item = (t === 'materia' ? materias : receitas).find(x => String(x.id) === String(id));
        if (!item || !qtd) return;
        let c = 0;
        if (t === 'materia') c = (item.custoPadrao / 1000) * qtd;
        else if (item.custoPorKg) c = (item.custoPorKg / 1000) * qtd;
        tempProd.push({ nome: item.nome, idOrigem: item.id, tipoOrigem: t, g: qtd, custo: c });
        document.getElementById('prod-qtd').value = '';
        renderTempProd();
    }

    function renderTempRec() {
        const container = document.getElementById('lista-temp-rec');
        if (tempRec.length === 0) { container.innerHTML = '<small style="color:#64748b">Nenhum ingrediente.</small>'; return; }
        let html = '<table class="admin-table"><thead><tr style="border-bottom:2px solid #cbd5e1;"><th align="left">Item</th><th align="right">Peso</th><th align="right">Unit.</th><th align="right">Total</th><th></th></tr></thead><tbody>';
        let tp = 0, tc = 0;
        tempRec.forEach((i, idx) => {
            tp += i.g; tc += i.custo;
            html += `<tr><td>${i.nome}</td><td align="right">${i.g.toFixed(0)}g</td><td align="right">R$ ${(i.custoUnitario||0).toFixed(2)}</td><td align="right">R$ ${i.custo.toFixed(2)}</td>
                <td align="center"><button onclick="tempRec.splice(${idx},1);renderTempRec()" style="color:red;background:none;border:none;cursor:pointer;">×</button></td></tr>`;
        });
        const precoKg = tp > 0 ? (tc / tp) * 1000 : 0;
        html += `</tbody><tfoot><tr style="font-weight:bold;background:#f1f5f9;"><td>TOTAL</td><td align="right">${tp.toFixed(0)}g</td><td></td><td align="right">R$ ${tc.toFixed(2)}</td><td></td></tr>
            <tr style="color:var(--primary);"><td colspan="3" align="right">PREÇO/KG:</td><td align="right">R$ ${precoKg.toFixed(2)}</td><td></td></tr></tfoot></table>`;
        container.innerHTML = html;
    }

    function renderTempProd() {
        const container = document.getElementById('lista-temp-prod');
        if (tempProd.length === 0) { container.innerHTML = '<small>Adicione massa, recheio, etc.</small>'; recalcularLive(); return; }
        let html = '<table class="admin-table"><thead><tr style="border-bottom:2px solid #cbd5e1;"><th align="left">Componente</th><th align="right">Peso</th><th align="right">Subtotal</th><th></th></tr></thead><tbody>';
        tempProd.forEach((i, idx) => {
            html += `<tr><td>${i.nome}</td><td align="right">${i.g}g</td><td align="right">R$ ${i.custo.toFixed(2)}</td>
                <td align="center"><button onclick="tempProd.splice(${idx},1);renderTempProd()" style="color:red;background:none;border:none;cursor:pointer;">×</button></td></tr>`;
        });
        container.innerHTML = html + '</tbody></table>';
        recalcularLive();
    }

    function recalcularLive() {
        const pt = tempProd.reduce((a, b) => a + parseFloat(b.g), 0);
        const ct = tempProd.reduce((a, b) => a + b.custo, 0);
        const pid = document.getElementById('prod-pack-select').value;
        const pcap = parseFloat(document.getElementById('prod-pack-cap').value) || 0;
        let ce = 0;
        if (pid && pcap > 0) {
            const e = materias.find(m => String(m.id) === String(pid));
            if (e) ce = (e.tipo === 'un' ? e.custoPadrao : e.custoPadrao / 1000) / pcap;
            document.getElementById('pack-cost-display').innerText = 'R$ ' + ce.toFixed(3);
        } else {
            document.getElementById('pack-cost-display').innerText = 'R$ 0,00';
        }
        const cf = ct + ce;
        let imp = parseFloat(document.getElementById('prod-imposto').value);
        if (isNaN(imp)) imp = 0;
        const m = pt < 100 ? 0.60 : 0.50;
        const d = 1 - ((imp / 100) + m);
        document.getElementById('live-peso').innerText = pt.toFixed(0);
        document.getElementById('live-margem').innerText = (m * 100).toFixed(0);
        document.getElementById('live-preco').innerText = 'R$ ' + (cf / (d > 0 ? d : 0.1)).toFixed(2);
    }

    // --- FINANCEIRO ---
    function renderFinanceiro() {
        const kpi = document.getElementById('kpi-financeiro');
        if (!kpi) return;
        if (!resumoFinanceiro) {
            kpi.innerHTML = '<p style="color:#64748b">Conecte a API para ver indicadores.</p>';
            document.getElementById('grid-status-pedidos').innerHTML = '';
            document.getElementById('grid-contas-receber').innerHTML = '';
            return;
        }
        const r = resumoFinanceiro;
        kpi.innerHTML = `
            <div class="kpi-card"><div class="label">Faturamento Total</div><div class="value">${formatarMoeda(r.faturamento_total)}</div></div>
            <div class="kpi-card"><div class="label">Pedidos</div><div class="value">${r.total_pedidos}</div></div>
            <div class="kpi-card"><div class="label">A Receber</div><div class="value" style="color:var(--warning)">${formatarMoeda(r.a_receber)}</div></div>
            <div class="kpi-card"><div class="label">Recebido (Entregue)</div><div class="value" style="color:var(--success)">${formatarMoeda(r.recebido)}</div></div>
            <div class="kpi-card"><div class="label">CMV Médio Produtos</div><div class="value">${parseFloat(r.cmv_medio_produtos).toFixed(1)}%</div></div>`;

        const statusRows = (r.pedidos_por_status || []).map(s => `
            <tr><td><span class="badge-status st-${s.status}">${s.status}</span></td><td>${s.quantidade}</td><td align="right">${formatarMoeda(s.valor)}</td></tr>`
        ).join('');
        document.getElementById('grid-status-pedidos').innerHTML = statusRows
            ? `<table class="data-table"><thead><tr><th>Status</th><th>Qtd</th><th align="right">Valor</th></tr></thead><tbody>${statusRows}</tbody></table>`
            : '<p style="padding:16px;color:#64748b">Nenhum pedido ainda.</p>';

        document.getElementById('grid-contas-receber').innerHTML = contasReceber.length
            ? `<table class="data-table"><thead><tr><th>Pedido</th><th>Cliente</th><th>Entrega</th><th>Status</th><th align="right">Valor</th><th></th></tr></thead><tbody>${
                contasReceber.map(c => `<tr>
                    <td>#${c.id}</td><td>${c.razao_social}</td><td>${formatarData(c.data_entrega)}</td>
                    <td><span class="badge-status st-${c.status}">${c.status}</span></td>
                    <td align="right">${formatarMoeda(c.valor_total)}</td>
                    <td><button class="btn-card btn-edit" onclick="abrirDetalhePedido(${c.id})">Editar</button></td>
                </tr>`).join('')
            }</tbody></table>`
            : '<p style="padding:16px;color:#64748b">Nenhuma conta pendente.</p>';
    }

    // --- INTERFACE ---
    function fecharModais() { document.querySelectorAll('.modal-overlay').forEach(m => m.classList.remove('open')); }
    function popSelect(t, id) {
        const el = document.getElementById(id);
        if (el && categorias[t]) el.innerHTML = categorias[t].map(c => `<option value="${c}">${c}</option>`).join('');
    }
    function setVal(id, v) { document.getElementById(id).value = v; }
    function resetForm(ids) { ids.forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; }); }
    function atualizarLabelPeso() {
        const t = document.getElementById('mat-tipo').value;
        document.getElementById('lbl-mat-qtd').innerText = t === 'kg' ? 'Peso TOTAL da Embalagem (g)' : 'Qtd na Embalagem (Un)';
        document.getElementById('mat-qtd').placeholder = t === 'kg' ? 'Ex: 1000' : 'Ex: 100';
    }

    function renderGrids() {
        const lm = filtroMat === 'todos' ? materias : materias.filter(x => x.categoria === filtroMat);
        document.getElementById('grid-materias').innerHTML = lm.length ? lm.map(m => `
            <div class="card">
                <div class="card-header"><span>${m.nome}</span><span class="card-tag">${m.categoria || 'Geral'}</span></div>
                <div>R$ ${m.custoPadrao.toFixed(2)} / ${m.tipo}</div>
                <div class="card-actions">
                    <button class="btn-card btn-edit" onclick="abrirModalMateria(${m.id})">Editar</button>
                    <button class="btn-card btn-del" onclick="excluirMateria(${m.id})">X</button>
                </div>
            </div>`).join('') : '<p style="color:#64748b">Nenhum insumo cadastrado.</p>';

        const lr = filtroRec === 'todos' ? receitas : receitas.filter(x => x.categoria === filtroRec);
        document.getElementById('grid-receitas').innerHTML = lr.length ? lr.map(r => `
            <div class="card">
                <div class="card-header"><span>${r.nome}</span><span class="card-tag">${r.categoria || 'Geral'}</span></div>
                <div style="font-size:0.9rem;color:#64748b">Custo Kg: <strong>R$ ${(r.custoPorKg || 0).toFixed(2)}</strong></div>
                <div style="font-size:0.8rem">Batelada: R$ ${(r.custo || 0).toFixed(2)} (${r.pesoTotal || 0}g)</div>
                <div class="card-actions">
                    <button class="btn-card btn-edit" onclick="abrirModalReceita(${r.id})">Editar</button>
                    <button class="btn-card btn-del" onclick="excluirReceita(${r.id})">X</button>
                </div>
            </div>`).join('') : '<p style="color:#64748b">Nenhuma receita cadastrada.</p>';

        const lp = filtroProd === 'todos' ? produtos : produtos.filter(x => x.categoria === filtroProd);
        document.getElementById('grid-produtos').innerHTML = lp.length ? lp.map(p => {
            const precoPraticado = p.mercado > 0 ? p.mercado : (p.precoSugerido || 0);
            const cmv = precoPraticado > 0 ? (p.custo / precoPraticado) * 100 : (p.cmv || 0);
            const lucro = precoPraticado - p.custo;
            const imp = p.imposto || 10;
            const margemReal = precoPraticado > 0 ? (1 - (imp / 100) - (p.custo / precoPraticado)) * 100 : (p.margem || 0);
            const cmvClass = cmv > 45 ? 'status-bad' : 'status-good';
            const lucroClass = lucro <= 0 ? 'status-bad' : 'status-good';
            const margemMeta = (p.peso || 0) < 100 ? 60 : 50;
            const corMargem = margemReal >= margemMeta ? 'var(--success)' : (margemReal > 0 ? 'var(--warning)' : 'var(--danger)');
            return `
            <div class="card">
                <div class="card-header"><span>${p.nome}</span><span class="card-tag">${p.peso || 0}g · ${p.categoria || 'Geral'}</span></div>
                <table class="admin-table">
                    <tr class="hide-print"><td>Custo Total</td><td class="value-cell">R$ ${(p.custo || 0).toFixed(2)}</td></tr>
                    <tr class="hide-print"><td>Preço Sugerido</td><td class="value-cell" style="color:var(--primary)">R$ ${(p.precoSugerido || precoPraticado).toFixed(2)}</td></tr>
                    <tr><td>Câmara Fria</td><td class="value-cell" style="color:var(--primary);font-weight:bold;">${p.estoqueAtual || 0} un</td></tr>
                    <tr><td>Preço de Venda</td><td class="value-cell" style="font-weight:bold;">R$ ${precoPraticado.toFixed(2)}</td></tr>
                    <tr class="hide-print"><td>Margem Real</td><td class="value-cell" style="color:${corMargem};font-weight:bold;">${margemReal.toFixed(1)}%</td></tr>
                    <tr class="hide-print"><td>CMV (%)</td><td class="value-cell ${cmvClass}">${cmv.toFixed(1)}%</td></tr>
                    <tr class="hide-print"><td>Lucro Bruto</td><td class="value-cell ${lucroClass}">R$ ${lucro.toFixed(2)}</td></tr>
                </table>
                <div class="card-actions">
                    <button class="btn-card btn-edit" onclick="abrirModalProduto(${p.id})">Editar</button>
                    <button class="btn-card btn-edit" onclick="ajustarEstoqueProduto(${p.id})">📦 Estoque</button>
                    <button class="btn-card btn-del" onclick="excluirProduto(${p.id})">X</button>
                </div>
            </div>`;
        }).join('') : '<p style="color:#64748b">Nenhum produto cadastrado.</p>';

        document.getElementById('grid-pedidos').innerHTML = pedidos.length
            ? `<table class="data-table"><thead><tr><th>#</th><th>Cliente</th><th>Data</th><th>Entrega</th><th>Itens</th><th>Status</th><th align="right">Total</th><th></th></tr></thead><tbody>${
                pedidos.map(p => `<tr>
                    <td><strong>#${p.id}</strong></td>
                    <td>${p.razao_social}</td>
                    <td>${formatarData(p.data_pedido)}</td>
                    <td>${formatarData(p.data_entrega)}</td>
                    <td>${p.total_itens}</td>
                    <td><span class="badge-status st-${p.status}">${p.status}</span></td>
                    <td align="right"><strong>${formatarMoeda(p.valor_total)}</strong></td>
                    <td><button class="btn-card btn-edit" onclick="abrirDetalhePedido(${p.id})">Ver / Editar</button></td>
                </tr>`).join('')
            }</tbody></table>`
            : '<p style="padding:20px;color:#64748b">Nenhum pedido lançado. Clique em "+ Lançar Pedido".</p>';

        document.getElementById('grid-clientes').innerHTML = clientes.length ? clientes.map(c => `
            <div class="card client-card">
                <div class="card-header"><span>${c.razao_social}</span></div>
                <div style="font-size:0.9rem;color:#475569;">CNPJ: ${c.cnpj}<br>Tel: ${c.telefone || '-'}</div>
                <div class="card-actions">
                    <button class="btn-card btn-edit" onclick="abrirModalCliente(${c.id})">Editar</button>
                </div>
            </div>`).join('') : '<p style="color:#64748b">Nenhum cliente cadastrado.</p>';

        document.getElementById('grid-producao').innerHTML = filaProducao.length ? filaProducao.map(op => `
            <div class="card op-card">
                <div class="card-header"><span style="color:#64748b;">OP #${op.numero_op}</span><span class="card-tag" style="background:#fef3c7;color:#b45309;">${op.status}</span></div>
                <div style="font-weight:600;margin:8px 0;">${op.produto}</div>
                <div>Fabricar: <strong>${op.quantidade_planejada} un</strong></div>
                <div style="font-size:0.8rem;color:#64748b;margin-top:4px;">Câmara Fria: ${op.estoque_camara_fria ?? 0} un</div>
                <div class="card-actions">
                    <button class="btn-card btn-edit" onclick="abrirModalIntercorrencia(${op.numero_op})">⚠️ Parada</button>
                    <button class="btn-card btn-del" onclick="excluirOP(${op.numero_op})">🗑️ Excluir</button>
                </div>
            </div>`).join('') : '<p style="color:#64748b">Fila de produção vazia.</p>';
    }

    window.onload = async function() { await carregarTodosOsDados(); };
</script>
