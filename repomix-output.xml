    <button class="btn btn-primary" onclick="submitInsumo(event)">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      Salvar Item
    </button>
  </div>
</div>

<div id="toast-container"></div>
<script>
  const API = 'http://localhost:3001/api';
  let allInsumos = [];
  let filtered   = [];
  const PAGE_SIZE = 7;
  let page = 1;

  function fmtBRL(v){ return Number(v||0).toLocaleString('pt-BR',{style:'currency',currency:'BRL'}); }
  function fmtDate(s){ if(!s) return '—'; return new Date(s).toLocaleDateString('pt-BR'); }
  function toast(msg,type=''){
    const el=document.createElement('div'); el.className='toast '+type; el.textContent=msg;
    document.getElementById('toast-container').appendChild(el);
    setTimeout(()=>el.remove(),3500);
  }

  async function loadInsumos() {
    try {
      const data = await fetch(`${API}/insumos`).then(r=>r.json());
      allInsumos = Array.isArray(data) ? data : [];
    } catch {
      allInsumos = [
        { id:1, sku:'MP-00124', nome:'Chapa de Aco Inox 304 - 2mm', estoque_atual:45, unidade_medida:'UN', localizacao:'CORREDOR-A1', ultima_entrada:'2024-05-12', custo_unitario:320.00, critico:false },
        { id:2, sku:'EL-00452', nome:'Cabo Flexivel 2.5mm Preto',    estoque_atual:12, unidade_medida:'MT', localizacao:'ELET-B4',     ultima_entrada:'2024-05-10', custo_unitario:4.50,  critico:true },
        { id:3, sku:'QU-00089', nome:'Solvente Desengraxante Industrial', estoque_atual:210, unidade_medida:'LT', localizacao:'QUIM-02', ultima_entrada:'2024-05-15', custo_unitario:18.90, critico:false },
        { id:4, sku:'FE-00912', nome:'Parafuso Sextavado M8x40',     estoque_atual:1250,unidade_medida:'UN', localizacao:'FIX-A2',     ultima_entrada:'2024-05-08', custo_unitario:0.45,  critico:false },
        { id:5, sku:'EP-00231', nome:'Luva Nitrilica Tamanho G',      estoque_atual:5,  unidade_medida:'PAR',localizacao:'EPI-01',     ultima_entrada:'2024-05-01', custo_unitario:3.20,  critico:true },
        { id:6, sku:'MP-00125', nome:'Viga U de Aluminio 4"',         estoque_atual:28, unidade_medida:'UN', localizacao:'CORREDOR-A3',ultima_entrada:'2024-05-14', custo_unitario:215.00,critico:false },
        { id:7, sku:'EM-00774', nome:'Filme Stretch para Paletizacao',estoque_atual:14, unidade_medida:'RL', localizacao:'EXP-C1',     ultima_entrada:'2024-05-11', custo_unitario:42.00, critico:false, alerta:true },
      ];
      toast('Servidor offline — dados de demonstracao.','error');
    }

    // compute KPIs
    const total   = allInsumos.length;
    const valor   = allInsumos.reduce((s,i)=>s+(i.estoque_atual||0)*(i.custo_unitario||0),0);
    const criticos= allInsumos.filter(i=>i.critico||i.estoque_atual<=5).length;

    document.getElementById('kpi-skus').textContent     = total.toLocaleString('pt-BR');
    document.getElementById('kpi-skus-sub').textContent = `+${Math.floor(total*0.01)} novos este mes`;
    document.getElementById('kpi-valor').textContent    = fmtBRL(valor);
    document.getElementById('kpi-criticos').textContent = criticos;

    filterInsumos();
  }

  function filterInsumos() {
    const q   = document.getElementById('alm-search').value.toLowerCase();
    const cat = document.querySelector('.cat-select').value;
    filtered = allInsumos.filter(i => {
      const matchQ  = !q || i.nome?.toLowerCase().includes(q) || i.sku?.toLowerCase().includes(q) || i.localizacao?.toLowerCase().includes(q);
      const matchCat= !cat || (i.sku||'').startsWith(cat);
      return matchQ && matchCat;
    });
    page = 1;
    renderTable();
  }

  function renderTable() {
    const start = (page-1)*PAGE_SIZE;
    const slice = filtered.slice(start, start+PAGE_SIZE);
    const tbody = document.getElementById('insumos-tbody');

    if(!slice.length) {
      tbody.innerHTML='<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted)">Nenhum item encontrado.</td></tr>';
    } else {
      tbody.innerHTML = slice.map(i => {
        const isCritico = i.critico || i.estoque_atual <= 5;
        const isAlerta  = i.alerta  || (!isCritico && i.estoque_atual <= 20);
        let qtyBadge = `<div class="qty-badge"><span class="qty-cell">${i.estoque_atual}</span>`;
        if (isCritico) qtyBadge += `<span class="badge-critico">CRITICO</span>`;
        else if (isAlerta) qtyBadge += `<span class="badge-alerta">ALERTA</span>`;
        qtyBadge += '</div>';

        return `<tr>
          <td><a class="sku-link" href="#">${i.sku || 'ID-'+i.id}</a></td>
          <td>${i.nome}</td>
          <td style="text-align:center">${qtyBadge}</td>
          <td><span class="badge badge-gray">${i.unidade_medida||'—'}</span></td>
          <td><span class="loc-dot"></span>${i.localizacao||'—'}</td>
          <td style="color:var(--text-muted);font-size:12.5px">${fmtDate(i.ultima_entrada||i.criado_em)}</td>
          <td style="text-align:right">
            <div class="action-icons" style="justify-content:flex-end">
              <button title="Adicionar estoque" onclick="ajustar(${i.id},+1)">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <button title="Remover estoque" class="red" onclick="ajustar(${i.id},-1)">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <button title="Transferir">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
              </button>
              <button title="Historico">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </button>
            </div>
          </td>
        </tr>`;
      }).join('');
    }

    const total = Math.ceil(filtered.length / PAGE_SIZE);
    document.getElementById('alm-info').textContent =
      `Exibindo ${start+1}–${Math.min(start+PAGE_SIZE,filtered.length)} de ${filtered.length} itens cadastrados`;
    renderPagination(total);
  }

  function renderPagination(total) {
    const pg = document.getElementById('alm-pagination');
    if(total<=1){pg.innerHTML='';return;}
    let html=`<button class="page-btn" onclick="goPage(${page-1})" ${page<=1?'disabled':''}>Anterior</button>`;
    for(let i=1;i<=Math.min(total,5);i++){
      html+=`<button class="page-btn ${i===page?'active':''}" onclick="goPage(${i})">${i}</button>`;
    }
    if(total>5) html+=`<span style="padding:0 4px">...</span><button class="page-btn ${total===page?'active':''}" onclick="goPage(${total})">${total}</button>`;
    html+=`<button class="page-btn" onclick="goPage(${page+1})" ${page>=total?'disabled':''}>Proximo</button>`;
    pg.innerHTML=html;
  }

  function goPage(p){
    const total=Math.ceil(filtered.length/PAGE_SIZE);
    if(p<1||p>total) return;
    page=p; renderTable();
  }

  function ajustar(id, delta) {
    const item = allInsumos.find(i=>i.id===id);
    if(!item) return;
    item.estoque_atual = Math.max(0, (item.estoque_atual||0)+delta);
    filterInsumos();
  }

  function openNovoInsumo(){
    document.getElementById('form-insumo').reset();
    document.getElementById('drawer').classList.add('open');
    document.getElementById('drawer-backdrop').classList.add('open');
  }
  function closeDrawer(){
    document.getElementById('drawer').classList.remove('open');
    document.getElementById('drawer-backdrop').classList.remove('open');
  }

  async function submitInsumo(e){
    if(e&&e.preventDefault) e.preventDefault();
    const form=document.getElementById('form-insumo');
    if(!form.reportValidity()) return;
    const payload={
      nome:         document.getElementById('f-nome').value,
      unidade_medida:document.getElementById('f-unidade').value,
      custo_unitario:parseFloat(document.getElementById('f-custo').value)||0,
      estoque_atual: parseFloat(document.getElementById('f-estoque').value)||0,
    };
    try {
      const res=await fetch(`${API}/insumos`,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(payload)});
      const data=await res.json();
      if(!res.ok) throw new Error(data.erro||'Erro');
      toast('Insumo cadastrado!','success');
      closeDrawer(); loadInsumos();
    } catch {
      const newItem={id:Date.now(),sku:'MP-'+String(Date.now()).slice(-5),...payload,localizacao:document.getElementById('f-local').value,critico:false};
      allInsumos.unshift(newItem);
      filterInsumos();
      toast('Item salvo localmente (modo offline).','');
      closeDrawer();
    }
  }

  document.addEventListener('keydown',e=>{if(e.key==='Escape') closeDrawer();});
  document.addEventListener('DOMContentLoaded', loadInsumos);
</script>
</body>
</html>
</file>

