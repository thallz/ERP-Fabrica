    async function carregarNecessidadeCompras(silencioso) {
        const grid = document.getElementById('grid-compras');
        const avisosEl = document.getElementById('mrp-avisos');
        if (!grid) return;
        if (!apiOnline) {
            grid.innerHTML = '<p style="padding:16px;color:#64748b">API offline.</p>';
            return;
        }
        const margem = document.getElementById('mrp-margem')?.value || '0';
        try {
            const res = await fetch(`${API_URL}/producao/necessidade-compras?margem=${margem}`);
            if (!res.ok) throw new Error();
            necessidadeCompras = await res.json();

            if (necessidadeCompras.avisos && necessidadeCompras.avisos.length) {
                avisosEl.innerHTML = necessidadeCompras.avisos.map(a =>
                    `<div style="background:#fef2f2;border:1px solid #fecaca;color:#991b1b;padding:10px;border-radius:8px;margin-bottom:8px;font-size:0.85rem;">⚠️ ${a}</div>`
                ).join('');
            } else {
                avisosEl.innerHTML = '';
            }

            const itens = necessidadeCompras.itens_comprar || [];
            if (!itens.length) {
                grid.innerHTML = `<p style="padding:20px;color:#64748b">Nenhuma compra necessária. ${necessidadeCompras.ops_na_fila || 0} OP(s) na fila — almoxarifado cobre a demanda.</p>`;
                textoWhatsAppCompras = '';
                return;
            }

            let total = 0;
            let linhas = '';
            itens.forEach(i => {
                total += i.custo_estimado;
                const qtdFmt = i.unidade_medida === 'kg' && i.quantidade_comprar < 1
                    ? (i.quantidade_comprar * 1000).toFixed(0) + ' g'
                    : i.quantidade_comprar.toFixed(i.unidade_medida === 'un' ? 0 : 3) + ' ' + i.unidade_medida;
                linhas += `<tr>
                    <td>${i.nome} <small style="color:#94a3b8">(${i.tipo})</small></td>
                    <td align="right">${i.demanda_total.toFixed(3)}</td>
                    <td align="right">${i.estoque_atual}</td>
                    <td align="right"><strong>${qtdFmt}</strong></td>
                    <td align="right">${formatarMoeda(i.custo_estimado)}</td>
                </tr>`;
            });

            grid.innerHTML = `<table class="data-table">
                <thead><tr>
                    <th>Insumo</th><th align="right">Demanda</th><th align="right">Estoque</th>
                    <th align="right">Comprar</th><th align="right">Custo Est.</th>
                </tr></thead>
                <tbody>${linhas}</tbody>
                <tfoot><tr style="font-weight:bold;background:#f8fafc;">
                    <td colspan="4" align="right">Total estimado</td>
                    <td align="right">${formatarMoeda(total)}</td>
                </tr></tfoot>
            </table>`;

            textoWhatsAppCompras = '🛒 *LISTA DE COMPRAS — ERP Fábrica*\n' +
                `OPs na fila: ${necessidadeCompras.ops_na_fila}\n\n` +
                itens.map(i => `• ${i.nome}: ${i.quantidade_comprar.toFixed(3)} ${i.unidade_medida}`).join('\n');
        } catch (e) {
            if (!silencioso) alert('Erro ao calcular necessidade de compras.');
            grid.innerHTML = '<p style="padding:16px;color:#ef4444">Erro ao carregar MRP.</p>';
        }
    }

