<!-- DRAWER: Novo Insumo -->
<div class="drawer-backdrop" id="drawer-backdrop" onclick="closeDrawer()"></div>
<div class="drawer" id="drawer">
  <div class="drawer-header">
    <h2>
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
      Novo Item de Estoque
    </h2>
    <p>Cadastre um novo insumo ou material no almoxarifado.</p>
    <button class="drawer-close" onclick="closeDrawer()">&#10005;</button>
  </div>
  <div class="drawer-body">
    <form id="form-insumo" onsubmit="submitInsumo(event)">
      <div class="form-section-title">Identificacao</div>
      <div class="form-group">
        <label>Nome do Item <span style="color:var(--red)">*</span></label>
        <input type="text" id="f-nome" placeholder="Ex: Chapa de Aco Inox 304 - 2mm" required />
      </div>
      <div class="form-row cols-2">
        <div class="form-group">
          <label>Unidade de Medida <span style="color:var(--red)">*</span></label>
          <select id="f-unidade" required>
            <option value="">Selecione...</option>
            <option>UN</option><option>KG</option><option>MT</option>
            <option>LT</option><option>PAR</option><option>RL</option>
            <option>CX</option><option>SC</option>
          </select>
        </div>
        <div class="form-group">
          <label>Localizacao</label>
