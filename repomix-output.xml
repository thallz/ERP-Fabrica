    async function salvarProduto() {
        const id = document.getElementById('edit-prod-id').value;
        const nome = document.getElementById('prod-nome').value;
        const cat = document.getElementById('prod-categoria').value;
        const imp = parseFloat(document.getElementById('prod-imposto').value) || 0;
        const mer = parseFloat(document.getElementById('prod-mercado').value) || 0;
        const pid = document.getElementById('prod-pack-select').value;
        const pcap = parseFloat(document.getElementById('prod-pack-cap').value) || 0;
        if (!nome || tempProd.length === 0) return alert('Preencha nome e componentes.');

        const pt = tempProd.reduce((a, b) => a + b.g, 0);
        const ct = tempProd.reduce((a, b) => a + b.custo, 0);
        let ce = 0;
        if (pid && pcap > 0) {
            const e = materias.find(m => String(m.id) === String(pid));
            if (e) ce = (e.tipo === 'un' ? e.custoPadrao : e.custoPadrao / 1000) / pcap;
        }
        const cf = ct + ce;
        const m = pt < 100 ? 0.60 : 0.50;
        const div = 1 - ((imp / 100) + m);
        const precoSugerido = cf / (div > 0 ? div : 0.1);
        const precoPraticado = mer > 0 ? mer : precoSugerido;
        const cmv = (cf / precoPraticado) * 100;
        const margem = (1 - (imp / 100) - (cf / precoPraticado)) * 100;

        const ficha = explodeTempProdToFicha(tempProd);
        const extra = { categoria: cat, imposto: imp, peso: pt, custo: cf, precoSugerido, precoMinimo: cf / (1 - (imp / 100)), itens: [...tempProd], embalagemId: pid, embalagemCap: pcap };

        if (!apiOnline) return alert('API offline. Inicie o backend na porta 3001.');

        try {
            const payload = { nome, preco_venda: precoPraticado, cmv_estimado: cmv, margem_contribuicao: margem, ficha_tecnica: ficha };
            const url = id ? `${API_URL}/produtos/${id}` : `${API_URL}/produtos`;
            const res = await fetch(url, {
                method: id ? 'PUT' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (!res.ok) throw new Error('Erro');
            const result = await res.json();
            const savedId = id || result.produto_id;
            const extras = getProdExtras();
            extras[savedId] = extra;
            setProdExtras(extras);
            fecharModais();
            await carregarTodosOsDados();
        } catch (e) {
            alert('Erro ao salvar produto.');
        }
    }

