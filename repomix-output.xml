<div id="toast-container"></div>
<script>
  const API = 'http://localhost:3001/api';
  let allFaturas = [];
  let filtered   = [];
  const PAGE_SIZE = 6;
  let page = 1;

  function fmtBRL(v) { return Number(v||0).toLocaleString('pt-BR',{style:'currency',currency:'BRL'}); }
  function fmtDate(s) { if(!s) return '—'; return new Date(s).toLocaleDateString('pt-BR'); }
  function isOverdue(s) {
    if(!s) return false;
    return new Date(s) < new Date() && new Date(s).toDateString() !== new Date().toDateString();
  }

  function toast(msg,type=''){
    const el=document.createElement('div'); el.className='toast '+type; el.textContent=msg;
    document.getElementById('toast-container').appendChild(el);
    setTimeout(()=>el.remove(),3500);
  }

  function statusBadge(s) {
    const map = {
      'CRIADO':    ['status-criado',   'Pendente'],
      'PRODUZINDO':['badge-blue',      'Em Producao'],
      'FATURADO':  ['status-pendente', 'Pendente'],
      'ENTREGUE':  ['status-pago',     'Pago'],
    };
    const [cls,label] = map[s]||['badge-gray',s];
    return `<span class="badge ${cls}">${label}</span>`;
  }

  async function loadFinanceiro() {
    try {
      const [resumo, contas] = await Promise.all([
        fetch(`${API}/financeiro/resumo`).then(r=>r.json()),
        fetch(`${API}/financeiro/contas-receber`).then(r=>r.json()),
      ]);

      document.getElementById('fin-vencer').textContent   = fmtBRL(resumo.a_receber);
      document.getElementById('fin-vencer-sub').textContent = `+12% em relacao ao mes anterior`;
      document.getElementById('fin-atrasado').textContent  = fmtBRL(resumo.pendente_producao);
      document.getElementById('fin-atrasado-sub').textContent = 'meta de reducao: &lt; R$30k';
      document.getElementById('fin-fluxo').textContent    = fmtBRL(resumo.faturamento_total);
      document.getElementById('rec-hoje').textContent     = fmtBRL(resumo.recebido);
      document.getElementById('rec-mes').textContent      = fmtBRL(resumo.recebido);
      document.getElementById('rec-total').textContent    = fmtBRL(resumo.faturamento_total);

      allFaturas = Array.isArray(contas) ? contas : [];
      filterFaturas();
    } catch(err) {
      toast('Servidor offline — dados de demonstracao.','error');
      document.getElementById('fin-vencer').textContent   = 'R$ 142.680,00';
      document.getElementById('fin-vencer-sub').textContent = '+12% em relacao ao mes anterior';
      document.getElementById('fin-atrasado').textContent  = 'R$ 48.500,00';
      document.getElementById('fin-atrasado-sub').textContent = 'meta de reducao: < R$30k';
      document.getElementById('fin-fluxo').textContent    = 'R$ 285.900,00';
      document.getElementById('rec-hoje').textContent     = 'R$ 4.200,00';
      document.getElementById('rec-mes').textContent      = 'R$ 87.400,00';
      document.getElementById('rec-total').textContent    = 'R$ 142.680,00';

      allFaturas = [
        { id:1, razao_social:'Metalurgica Silva S.A.', doc:'FAT-8842', data_entrega:'2024-05-15', valor_total:12450.00, status:'FATURADO' },
        { id:2, razao_social:'Construtora Horizonte',  doc:'FAT-8843', data_entrega:'2024-05-10', valor_total:45300.00, status:'CRIADO' },
        { id:3, razao_social:'Pecas Automotivas Turbo',doc:'FAT-8845', data_entrega:'2024-05-22', valor_total:8900.00,  status:'FATURADO' },
        { id:4, razao_social:'Distribuidora Industrial',doc:'FAT-8790',data_entrega:'2024-04-30', valor_total:3200.00,  status:'CRIADO' },
        { id:5, razao_social:'Moveis Projetados Ltda', doc:'FAT-8850', data_entrega:'2024-05-28', valor_total:15600.00, status:'ENTREGUE' },
        { id:6, razao_social:'Serralheria Modelo',     doc:'FAT-8851', data_entrega:'2024-06-05', valor_total:2150.00,  status:'FATURADO' },
      ];
      filterFaturas();
    }
  }

  function filterFaturas() {
    const q = document.getElementById('fin-search').value.toLowerCase();
    filtered = allFaturas.filter(f =>
      f.razao_social?.toLowerCase().includes(q) ||
      (f.doc||String(f.id)).toLowerCase().includes(q)
    );
    page = 1;
    renderTable();
  }

  function renderTable() {
    const start = (page-1)*PAGE_SIZE;
    const slice = filtered.slice(start, start+PAGE_SIZE);
    const tbody = document.getElementById('faturas-tbody');

    if(!slice.length) {
      tbody.innerHTML='<tr><td colspan="6" style="text-align:center;padding:30px;color:var(--text-muted)">Nenhuma fatura encontrada.</td></tr>';
    } else {
      tbody.innerHTML = slice.map(f => {
        const doc     = f.doc || `FAT-${String(f.id).padStart(4,'0')}`;
        const overdue = isOverdue(f.data_entrega) && f.status !== 'ENTREGUE';
        return `<tr>
          <td style="font-weight:500">${f.razao_social}</td>
          <td class="doc-col">${doc}</td>
          <td class="${overdue?'date-overdue':''}">${fmtDate(f.data_entrega)}</td>
          <td class="value-col">${fmtBRL(f.valor_total)}</td>
          <td>${statusBadge(f.status)}</td>
          <td>
            <div class="action-icons">
              <button title="Marcar como pago">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
              </button>
              <button title="Comentario">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              </button>
              <button title="Opcoes">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
              </button>
            </div>
          </td>
        </tr>`;
      }).join('');
    }

    const total = Math.ceil(filtered.length / PAGE_SIZE);
    document.getElementById('faturas-info').textContent =
      `Exibindo ${start+1}–${Math.min(start+PAGE_SIZE,filtered.length)} de ${filtered.length} faturas`;
    document.getElementById('btn-prev').disabled = page<=1;
    document.getElementById('btn-next').disabled = page>=total;
  }

  function goPage(dir) {
    const total = Math.ceil(filtered.length/PAGE_SIZE);
    page = Math.max(1, Math.min(total, page+dir));
    renderTable();
  }

  document.addEventListener('DOMContentLoaded', loadFinanceiro);
</script>
</body>
</html>
