<div id="toast-container"></div>

<script>
  const API = 'http://localhost:3001/api';
  let allClientes = [];
  let filtered = [];
  const PAGE_SIZE = 10;
  let currentPage = 1;

  function fmtDate(s) {
    if (!s) return '—';
    return new Date(s).toLocaleDateString('pt-BR');
  }
  function fmtCNPJ(s) {
    if (!s) return '—';
    return s.replace(/(\d{2})(\d{3})(\d{3})(\d{4})(\d{2})/, '$1.$2.$3/$4-$5');
  }
  function toast(msg, type = '') {
    const el = document.createElement('div');
    el.className = 'toast ' + type;
    el.textContent = msg;
    document.getElementById('toast-container').appendChild(el);
    setTimeout(() => el.remove(), 3500);
  }

  // --- Load clientes ---
  async function loadClientes() {
    try {
      const data = await fetch(`${API}/comercial/clientes`).then(r => r.json());
      allClientes = Array.isArray(data) ? data : [];
    } catch {
      allClientes = [
        { id:1, razao_social:'Metalurgica Avancada Ltda', cnpj:'12345678000190', telefone:'(11) 4002-8922', criado_em:'2024-01-10' },
        { id:2, razao_social:'Industria de Plasticos Globo', cnpj:'98765432000110', telefone:'(19) 3456-7890', criado_em:'2024-02-14' },
        { id:3, razao_social:'Construtora Horizonte S.A.', cnpj:'45678901000155', telefone:'(21) 2345-6789', criado_em:'2024-03-01' },
        { id:4, razao_social:'Tecnologia em Usinagem Precisao', cnpj:'23456789000133', telefone:'(47) 9987-6543', criado_em:'2024-03-20' },
        { id:5, razao_social:'Distribuidora de Aco Brasil', cnpj:'34567890000122', telefone:'(31) 3333-4444', criado_em:'2024-04-05' },
        { id:6, razao_social:'Padaria Centro Ltda', cnpj:'11222333000199', telefone:'(11) 9999-8888', criado_em:'2024-05-01' },
      ];
      toast('Servidor offline — dados de demonstracao.', 'error');
    }
    filterClientes();
  }

  function filterClientes() {
    const q = document.getElementById('search-input').value.toLowerCase();
    filtered = allClientes.filter(c =>
      c.razao_social?.toLowerCase().includes(q) ||
      c.cnpj?.includes(q) ||
      c.telefone?.includes(q)
    );
    currentPage = 1;
    renderTable();
  }

  function renderTable() {
    const start = (currentPage - 1) * PAGE_SIZE;
    const page  = filtered.slice(start, start + PAGE_SIZE);
    const tbody = document.getElementById('clientes-tbody');

    if (!page.length) {
      tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:30px;color:var(--text-muted)">Nenhum cliente encontrado.</td></tr>';
    } else {
      tbody.innerHTML = page.map(c => `
        <tr>
          <td class="checkbox-col"><input type="checkbox" class="row-check" /></td>
          <td><span style="font-weight:500">${c.razao_social}</span></td>
          <td class="cnpj-col">${fmtCNPJ(c.cnpj)}</td>
          <td>${c.telefone || '—'}</td>
          <td>${fmtDate(c.criado_em)}</td>
          <td>
            <button class="btn btn-outline btn-sm" onclick="openEdit(${c.id})">Editar</button>
          </td>
        </tr>`).join('');
    }

    document.getElementById('table-info').textContent =
      `Exibindo ${start + 1}-${Math.min(start + PAGE_SIZE, filtered.length)} de ${filtered.length} registros`;

    renderPagination();
  }

  function renderPagination() {
    const total = Math.ceil(filtered.length / PAGE_SIZE);
    const pg = document.getElementById('pagination');
    if (total <= 1) { pg.innerHTML = ''; return; }
    let html = `<button class="page-btn" onclick="goPage(${currentPage-1})" ${currentPage===1?'disabled':''}>Anterior</button>`;
    for (let i = 1; i <= total; i++) {
      html += `<button class="page-btn ${i===currentPage?'active':''}" onclick="goPage(${i})">${i}</button>`;
    }
    html += `<button class="page-btn" onclick="goPage(${currentPage+1})" ${currentPage===total?'disabled':''}>Proximo</button>`;
    pg.innerHTML = html;
  }

  function goPage(p) {
    const total = Math.ceil(filtered.length / PAGE_SIZE);
    if (p < 1 || p > total) return;
    currentPage = p;
    renderTable();
  }

  function toggleAll(cb) {
    document.querySelectorAll('.row-check').forEach(c => c.checked = cb.checked);
  }

  // --- Drawer ---
  function openDrawer(id) {
    document.getElementById('drawer-title').textContent    = id ? 'Editar Cliente' : 'Novo Cadastro de Cliente';
    document.getElementById('drawer-subtitle').textContent = id ? 'Atualize os dados do parceiro.' : 'Preencha os dados abaixo para registrar um novo parceiro.';
    document.getElementById('form-cliente').reset();
    document.getElementById('edit-id').value = id || '';
    document.getElementById('drawer').classList.add('open');
    document.getElementById('drawer-backdrop').classList.add('open');
  }

  function openEdit(id) {
    const c = allClientes.find(x => x.id === id);
    if (!c) return;
    openDrawer(id);
    document.getElementById('f-razao').value    = c.razao_social || '';
    document.getElementById('f-cnpj').value     = c.cnpj || '';
    document.getElementById('f-telefone').value = c.telefone || '';
  }

  function closeDrawer() {
    document.getElementById('drawer').classList.remove('open');
    document.getElementById('drawer-backdrop').classList.remove('open');
  }

  async function submitCliente(e, andNew = false) {
    if (e && e.preventDefault) e.preventDefault();
    const form = document.getElementById('form-cliente');
    if (!form.reportValidity()) return;

    const id      = document.getElementById('edit-id').value;
    const payload = {
      razao_social: document.getElementById('f-razao').value,
      cnpj:         document.getElementById('f-cnpj').value.replace(/\D/g,''),
      telefone:     document.getElementById('f-telefone').value,
    };

    try {
      const url    = id ? `${API}/comercial/clientes/${id}` : `${API}/comercial/clientes`;
      const method = id ? 'PUT' : 'POST';
      const res    = await fetch(url, { method, headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload) });
      const data   = await res.json();
      if (!res.ok) throw new Error(data.erro || 'Erro ao salvar');
      toast(id ? 'Cliente atualizado com sucesso!' : 'Cliente cadastrado com sucesso!', 'success');
      loadClientes();
      if (andNew) { form.reset(); document.getElementById('edit-id').value=''; }
      else closeDrawer();
    } catch (err) {
      // Demo mode: add locally
      if (!id) {
        const newC = { id: Date.now(), ...payload, criado_em: new Date().toISOString() };
        allClientes.unshift(newC);
        filterClientes();
        toast('Cliente salvo localmente (modo offline).', '');
        if (andNew) form.reset();
        else closeDrawer();
      } else {
        toast('Erro: ' + err.message, 'error');
      }
    }
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrawer(); });
  document.addEventListener('DOMContentLoaded', loadClientes);
</script>
</body>
</html>
