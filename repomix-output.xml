<!DOCTYPE html>
<html lang="pt">
<head>
    
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ERP Fábrica | Versão Definitiva B2B</title>
    <style>
        :root { --primary: #2563eb; --success: #059669; --warning: #d97706; --danger: #dc2626; --bg: #f8fafc; --text: #1e293b; --border: #e2e8f0; --white: #ffffff; --modal-bg: rgba(15, 23, 42, 0.9); }
        body { font-family: 'Inter', system-ui, sans-serif; background-color: var(--bg); color: var(--text); margin: 0; line-height: 1.5; }

        nav { background: var(--white); border-bottom: 1px solid var(--border); padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 50; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
        .nav-links { display: flex; gap: 10px; flex-wrap: wrap; }
        .nav-links button { background: none; border: none; font-weight: 600; color: #64748b; cursor: pointer; padding: 10px 15px; transition: 0.3s; border-radius: 6px; }
        .nav-links button.active { color: var(--primary); background: #eff6ff; border-bottom: 2px solid var(--primary); }
        .btn-system { background: #1e293b; color: white; display: flex; align-items: center; gap: 8px; padding: 8px 16px; border-radius: 6px; cursor: pointer; border: none; font-size: 0.9rem; }

        .container { max-width: 1200px; margin: 2rem auto; padding: 0 1rem; }
        .section { display: none; }
        .section.active { display: block; animation: fadeIn 0.3s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }

        .header-actions { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 10px; }
        h2 { margin: 0; font-size: 1.8rem; color: #0f172a; }
        .btn-group { display: flex; gap: 10px; flex-wrap: wrap; }
        button.btn-primary { background: var(--primary); color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 600; }
        button.btn-config { background: #e2e8f0; color: #475569; border: none; padding: 10px; border-radius: 8px; cursor: pointer; transition: 0.2s; font-weight: bold; }

        .filter-bar { display: flex; gap: 10px; margin-bottom: 20px; overflow-x: auto; padding-bottom: 10px; border-bottom: 1px solid #f1f5f9; }
        .filter-btn { background: white; border: 1px solid var(--border); padding: 6px 16px; border-radius: 20px; font-size: 0.85rem; color: #64748b; cursor: pointer; transition: 0.2s; white-space: nowrap; }
        .filter-btn.active { background: var(--primary); color: white; border-color: var(--primary); }

        .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
        .card { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; display: flex; flex-direction: column; transition: 0.3s; }
        .card:hover { transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); }
        .card-header { display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-weight: 700; font-size: 1.1rem; align-items: flex-start; }
        .card-tag { font-size: 0.7rem; padding: 2px 8px; border-radius: 4px; background: #f1f5f9; color: #64748b; font-weight: normal; margin-top: 5px; display: inline-block; }
        .admin-table { width: 100%; font-size: 0.85rem; margin-top: auto; border-collapse: separate; border-spacing: 0; background: #f8fafc; border-radius: 8px; padding: 10px; }
        .admin-table td { padding: 4px 0; border-bottom: 1px dashed #e2e8f0; }
        .value-cell { text-align: right; font-weight: 600; }
        .status-good { color: var(--success); font-weight: bold; }
        .status-bad { color: var(--danger); font-weight: bold; }
        .card-actions { margin-top: 1rem; padding-top: 1rem; border-top: 1px solid var(--border); display: flex; gap: 10px; }
        .btn-card { flex: 1; padding: 8px; border-radius: 6px; border: none; cursor: pointer; font-weight: 600; font-size: 0.85rem; }
        .btn-edit { background: #f1f5f9; color: #334155; }
        .btn-del { background: #fee2e2; color: #ef4444; }

        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--modal-bg); z-index: 100; backdrop-filter: blur(4px); align-items: center; justify-content: center; }
        .modal-overlay.open { display: flex; }
        .modal-content { background: white; width: 90%; max-width: 650px; border-radius: 16px; padding: 2rem; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); max-height: 90vh; overflow-y: auto; }
        .close-modal { float: right; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #64748b; }
        .grid-form { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 1.5rem; }
        .input-group { display: flex; flex-direction: column; gap: 6px; }
        label { font-size: 0.85rem; font-weight: 600; color: #475569; }
        input, select { padding: 12px; border: 1px solid var(--border); border-radius: 8px; outline: none; }
        .temp-list { background: #f8fafc; padding: 1rem; border-radius: 8px; border: 1px dashed #cbd5e1; margin-bottom: 1.5rem; }
        .cat-list-item { display: flex; justify-content: space-between; padding: 10px; border-bottom: 1px solid #eee; }
        .live-summary { background: #ecfdf5; border: 1px solid #a7f3d0; color: #065f46; padding: 15px; border-radius: 8px; font-weight: 600; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; margin-bottom: 15px; }
        .pack-area { background: #fff7ed; border: 1px solid #fed7aa; padding: 15px; border-radius: 8px; margin-bottom: 15px; }
        .op-card { border-left: 5px solid var(--warning); }
        .client-card { border-left: 5px solid var(--primary); }
        .api-status { font-size: 0.75rem; padding: 4px 10px; border-radius: 20px; }
        .api-online { background: #dcfce7; color: #166534; }
        .api-offline { background: #fee2e2; color: #991b1b; }

        .module-nav { background: #0f172a; padding: 0 2rem; display: flex; gap: 0; }
        .module-nav button { background: none; border: none; color: #94a3b8; font-weight: 700; font-size: 0.95rem; padding: 14px 24px; cursor: pointer; border-bottom: 3px solid transparent; transition: 0.2s; }
        .module-nav button.active { color: white; border-bottom-color: var(--primary); background: rgba(37,99,235,0.15); }
        .modulo { display: none; }
        .modulo.active { display: block; }
        .sub-nav { background: var(--white); border-bottom: 1px solid var(--border); padding: 0.75rem 2rem; display: flex; gap: 8px; flex-wrap: wrap; }
        .sub-nav button { background: #f1f5f9; border: 1px solid var(--border); color: #475569; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 0.85rem; }
        .sub-nav button.active { background: var(--primary); color: white; border-color: var(--primary); }
        .sub-section { display: none; }
        .sub-section.active { display: block; animation: fadeIn 0.3s ease; }
        .kpi-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
        .kpi-card { background: white; border: 1px solid var(--border); border-radius: 12px; padding: 1.25rem; }
        .kpi-card .label { font-size: 0.8rem; color: #64748b; margin-bottom: 4px; }
        .kpi-card .value { font-size: 1.5rem; font-weight: 800; color: #0f172a; }
        .data-table-wrap { background: white; border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
        .data-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        .data-table th { background: #f8fafc; text-align: left; padding: 12px 16px; font-weight: 700; color: #475569; border-bottom: 1px solid var(--border); }
        .data-table td { padding: 12px 16px; border-bottom: 1px solid #f1f5f9; }
        .data-table tr:hover td { background: #f8fafc; }
        .badge-status { padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 700; }
        .st-CRIADO { background: #e0e7ff; color: #3730a3; }
        .st-PRODUZINDO { background: #fef3c7; color: #b45309; }
        .st-FATURADO { background: #dbeafe; color: #1d4ed8; }
        .st-ENTREGUE { background: #dcfce7; color: #166534; }
        .pedido-card { border-left: 5px solid var(--primary); }

        @media print {
            nav, .module-nav, .sub-nav, .header-actions, .filter-bar, .modal-overlay, #modulo-comercial, #modulo-financeiro, #prod-materia, #prod-receitas, #prod-fabrica { display: none !important; }
            body { background: white; color: black; font-family: 'Times New Roman', serif; font-size: 12pt; }
            .container { max-width: 100%; margin: 0; padding: 0; }
            .section { display: block !important; }
            #prod-produtos::before { content: "Tabela de Preços"; display: block; font-size: 24px; font-weight: bold; text-align: center; margin-bottom: 20px; border-bottom: 2px solid black; }
            .cards-grid { display: block; }
            .card { border: none; border-bottom: 1px dashed #999; border-radius: 0; box-shadow: none; padding: 10px 0; margin: 0; page-break-inside: avoid; }
            .card-actions, .btn-group, button, .card-tag { display: none !important; }
            .admin-table { background: none; width: 100%; margin: 0; padding: 0; }
            .admin-table td { border: none; padding: 2px 0; font-size: 12pt; }
            .value-cell { font-weight: bold; color: black !important; text-align: right; }
            .hide-print { display: none !important; }
        }
    </style>
</head>
<body>

<nav>
    <div style="display:flex; justify-content:space-between; align-items:center; padding:0.75rem 2rem; background:var(--white); border-bottom:1px solid var(--border);">
        <strong style="font-size:1.1rem; color:#0f172a;">ERP Fábrica de Salgados</strong>
        <div style="display:flex; gap:10px; align-items:center;">
