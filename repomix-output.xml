<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <script src="https://tailwindcss.com"></script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard — ERP Fabrica</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="css/global.css" />
  <style>
    /* Dashboard-specific layout */
    .dashboard-grid {
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 20px;
      margin-bottom: 24px;
    }
    .chart-container { position: relative; height: 280px; }
    canvas#salesChart { width: 100% !important; height: 100% !important; }

    .queue-list { list-style: none; }
    .queue-item {
      padding: 12px 0;
      border-bottom: 1px solid var(--border-light);
    }
    .queue-item:last-child { border-bottom: none; }
    .queue-item-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 3px;
    }
    .queue-item-title { font-size: 13.5px; font-weight: 600; }
    .queue-item-sub   { font-size: 12px; color: var(--text-muted); }
    .queue-item-op    { font-size: 11.5px; font-weight: 600; color: var(--text-secondary); }

    .shortcuts-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .shortcut-btn {
      display: flex; flex-direction: column; align-items: center;
      gap: 8px; padding: 20px 12px;
      border: 1px solid var(--border); border-radius: var(--radius-lg);
      background: var(--surface); cursor: pointer;
      font-size: 12.5px; font-weight: 500; color: var(--text-secondary);
      transition: border-color .15s, color .15s, background .15s;
      text-decoration: none;
    }
    .shortcut-btn:first-child {
      background: var(--brand); color: #fff; border-color: var(--brand);
    }
    .shortcut-btn:first-child:hover { background: var(--brand-hover); }
    .shortcut-btn:not(:first-child):hover { border-color: var(--brand); color: var(--brand); background: var(--brand-light); }

    .period-input-wrap {
      display: flex; align-items: center; gap: 8px;
      border: 1px solid var(--border); border-radius: var(--radius);
      padding: 8px 12px; background: var(--bg); font-size: 13px;
      color: var(--text-secondary); margin-bottom: 14px;
    }
    .legend-dots { display: flex; gap: 14px; margin-top: 12px; font-size: 11.5px; }
    .legend-dot { display: flex; align-items: center; gap: 5px; color: var(--text-muted); }
    .dot { width: 8px; height: 8px; border-radius: 50%; }

