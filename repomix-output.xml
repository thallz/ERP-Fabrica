    function explodeTempProdToFicha(temp) {
        const mapa = {};
        temp.forEach(item => {
            if (item.tipoOrigem === 'materia') {
                const qty = item.g / 1000;
                mapa[item.idOrigem] = (mapa[item.idOrigem] || 0) + qty;
            } else {
                const rec = receitas.find(r => String(r.id) === String(item.idOrigem));
                if (!rec || !rec.pesoTotal) return;
                rec.itens.forEach(sub => {
                    if (sub.tipoOrigem !== 'materia') return;
                    const qty = ((sub.g / rec.pesoTotal) * item.g) / 1000;
                    mapa[sub.idOrigem] = (mapa[sub.idOrigem] || 0) + qty;
                });
            }
        });
        return Object.entries(mapa).map(([insumo_id, quantidade]) => ({ insumo_id: Number(insumo_id), quantidade }));
    }

