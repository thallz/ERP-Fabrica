            <div class="input-group"><label>Cliente</label><input type="text" id="det-ped-cliente" readonly></div>
            <div class="input-group"><label>Status</label>
                <select id="det-ped-status">
                    <option value="CRIADO">CRIADO</option>
                    <option value="PRODUZINDO">PRODUZINDO</option>
                    <option value="FATURADO">FATURADO</option>
                    <option value="ENTREGUE">ENTREGUE</option>
                </select>
            </div>
            <div class="input-group"><label>Data Entrega</label><input type="date" id="det-ped-entrega"></div>
            <div class="input-group"><label>Valor Total</label><input type="text" id="det-ped-total" readonly></div>
        </div>
        <div id="det-ped-itens" class="temp-list" style="margin-bottom:15px;"></div>
        <button class="btn-primary" style="width:100%" onclick="salvarStatusPedido()">Salvar Alterações</button>
    </div>
</div>

<div id="modal-pedido" class="modal-overlay">
    <div class="modal-content">
        <button class="close-modal" onclick="fecharModais()">&times;</button>
        <h3>Lançar Pedido de Venda</h3>
        <div class="grid-form">
            <div class="input-group"><label>Cliente</label><select id="ped-cliente"></select></div>
            <div class="input-group"><label>Data de Entrega</label><input type="date" id="ped-data"></div>
        </div>
        <div style="background:#f1f5f9; padding:15px; border-radius:8px; margin-bottom:15px; display:flex; gap:10px;">
            <select id="ped-produto" style="flex:3;"></select>
            <input type="number" id="ped-qtd" placeholder="Quantidade" style="flex:1;">
