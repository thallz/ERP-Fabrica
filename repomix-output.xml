<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Almoxarifado — ERP Fabrica</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="css/global.css" />
  <style>
    .alm-kpi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }

    .toolbar {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 16px; flex-wrap: wrap;
    }
    .toolbar .search-bar { flex: 1; max-width: 380px; }
    .toolbar-right { margin-left: auto; display: flex; gap: 8px; align-items: center; }

    .sku-link { color: var(--brand); font-weight: 600; font-size: 12.5px; cursor: pointer; text-decoration: none; }
    .sku-link:hover { text-decoration: underline; }

    .qty-cell { font-size: 15px; font-weight: 700; }
    .qty-badge { display: inline-flex; flex-direction: column; align-items: flex-start; gap: 2px; }
    .badge-critico { background: #fee2e2; color: var(--red); font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 20px; }
    .badge-alerta  { background: #fef3c7; color: var(--amber); font-size: 10px; font-weight: 700; padding: 1px 6px; border-radius: 20px; }

    .loc-dot { display: inline-block; width: 7px; height: 7px; border-radius: 50%; background: var(--brand); margin-right: 5px; }

    .action-icons { display: flex; gap: 4px; }
    .action-icons button, .action-icons a {
      width: 26px; height: 26px;
      display: flex; align-items: center; justify-content: center;
      border: 1px solid var(--border); border-radius: 6px;
      background: var(--surface); cursor: pointer;
      color: var(--text-secondary);
      transition: border-color .12s, color .12s;
      text-decoration: none;
    }
    .action-icons button:hover, .action-icons a:hover { border-color: var(--brand); color: var(--brand); }
    .action-icons button.red:hover { border-color: var(--red); color: var(--red); }

    .tbl-footer {
      display: flex; align-items: center; justify-content: space-between;
      padding: 12px 16px; border-top: 1px solid var(--border);
      font-size: 12.5px; color: var(--text-muted); flex-wrap: wrap; gap: 8px;
    }

    select.cat-select {
      width: auto; min-width: 160px; padding: 7px 12px;
      border: 1px solid var(--border); border-radius: var(--radius);
      font-size: 13px; background: var(--surface);
    }

    @media(max-width:800px) { .alm-kpi-grid { grid-template-columns: 1fr; } }
  </style>
</head>
